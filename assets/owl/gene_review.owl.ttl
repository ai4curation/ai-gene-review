gene_review:Descriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "Descriptor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:term ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:preferred_term ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:preferred_term ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:evidence ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:EvidenceItem ;
            owl:onProperty gene_review:evidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:term ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:term ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:preferred_term ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:description ] ;
    skos:definition "A human-friendly descriptor with optional ontology/database grounding. The preferred_term may be more nuanced than the term label, and the term may be absent when no good identifier exists yet." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

