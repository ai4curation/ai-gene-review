@prefix ECO: <http://purl.obolibrary.org/obo/ECO_> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .
@prefix SO: <http://purl.obolibrary.org/obo/SO_> .
@prefix gene_review: <https://w3id.org/ai4curation/gene_review/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

gene_review:ChemicalEntityDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ChemicalEntityDescriptor" ;
    rdfs:subClassOf gene_review:Descriptor ;
    skos:definition "A descriptor for a chemical entity, metabolite, cofactor, ion, or small molecule." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:GOBiologicalProcessEnum a owl:Class,
        linkml:EnumDefinition .

gene_review:GOCellularLocationEnum a owl:Class,
        linkml:EnumDefinition .

gene_review:GOMolecularActivityEnum a owl:Class,
        linkml:EnumDefinition .

gene_review:GOProteinContainingComplexEnum a owl:Class,
        linkml:EnumDefinition .

gene_review:GOTermEnum a owl:Class,
        linkml:EnumDefinition .

gene_review:GeneReview a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "GeneReview" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ProposedOntologyTerm ;
            owl:onProperty gene_review:proposed_new_terms ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:tags ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:GeneReviewStatusEnum ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:suggested_questions ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ProductTypeEnum ;
            owl:onProperty gene_review:product_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:gene_symbol ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ExistingAnnotation ;
            owl:onProperty gene_review:existing_annotations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:gene_symbol ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:aliases ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:alternative_products ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:proposed_new_terms ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:tags ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:core_functions ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Experiment ;
            owl:onProperty gene_review:suggested_experiments ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:suggested_experiments ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:taxon ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:product_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:references ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:functional_isoforms ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:CoreFunction ;
            owl:onProperty gene_review:core_functions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:knowledge_gaps ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:FunctionalIsoform ;
            owl:onProperty gene_review:functional_isoforms ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Reference ;
            owl:onProperty gene_review:references ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Question ;
            owl:onProperty gene_review:suggested_questions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:aliases ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:AlternativeProduct ;
            owl:onProperty gene_review:alternative_products ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:taxon ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:KnowledgeGap ;
            owl:onProperty gene_review:knowledge_gaps ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:existing_annotations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:product_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:taxon ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:gene_symbol ] ;
    skos:definition "Complete review for a gene" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ModuleReview a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ModuleReview" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:evidence ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:KnowledgeGap ;
            owl:onProperty gene_review:knowledge_gaps ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ModuleNode ;
            owl:onProperty gene_review:module ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:EvidenceItem ;
            owl:onProperty gene_review:evidence ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:knowledge_gaps ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:module ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:references ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Reference ;
            owl:onProperty gene_review:references ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:module ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:description ] ;
    skos:definition "Review or curation record for a recursively decomposable biological module. This can describe a pathway, organelle lifecycle, protein complex, molecular function, developmental process, or abstract/evolutionary functional plan." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:PredictionReview a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "PredictionReview" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:GeneReviewStatusEnum ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:locus_tag ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:taxon ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:references ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:PredictedAnnotation ;
            owl:onProperty gene_review:predictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:source_documents ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:locus_tag ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:gene_symbol ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:taxon ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:source_documents ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:predictions ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:taxon ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Reference ;
            owl:onProperty gene_review:references ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:gene_symbol ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:gene_symbol ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:locus_tag ] ;
    skos:definition "Review of computational/ML predictions for a gene that are NOT in the curated GOA/UniProt annotations. This captures predictions from methods like DeepECTF, PANTHER/IBA, InterPro2GO, CLEAN, GloEC, MAPred, etc. and evaluates them against literature and bioinformatic evidence. Inspired by the systematic evaluation in de Crécy-Lagard et al. 2025 (PMID:40703034)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ROTermEnum a owl:Class,
        linkml:EnumDefinition .

gene_review:RuleReview a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "RuleReview" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:rule_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:taxonomic_scope ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:review_summary ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:EmbeddedRule ;
            owl:onProperty gene_review:rule ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:action_rationale ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:confidence ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:literature_support ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:action ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:GOSpecificityAssessment ;
            owl:onProperty gene_review:go_specificity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ParsimonyAssessment ;
            owl:onProperty gene_review:parsimony ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:taxonomic_scope ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:rule ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:rule_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:go_specificity ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:condition_overlap ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:action_rationale ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:action ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:TaxonomicScopeAssessment ;
            owl:onProperty gene_review:taxonomic_scope ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:parsimony ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:parsimony ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:references ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:action_rationale ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:rule ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:go_specificity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:review_summary ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:confidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:RuleReviewStatusEnum ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Reference ;
            owl:onProperty gene_review:references ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:suggested_modifications ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:SupportingTextInReference ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ConditionOverlapAssessment ;
            owl:onProperty gene_review:condition_overlap ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:LiteratureSupportAssessment ;
            owl:onProperty gene_review:literature_support ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:review_summary ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:suggested_modifications ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:RuleTypeEnum ;
            owl:onProperty gene_review:rule_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:RuleActionEnum ;
            owl:onProperty gene_review:action ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:condition_overlap ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1e+00 ] ) ] ) ] ;
            owl:onProperty gene_review:confidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:literature_support ] ;
    skos:definition "A review of a UniProt annotation rule (ARBA or UniRule). Each review covers ONE rule and assesses its quality, literature support, and biological appropriateness." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:AnatomicalEntityDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "AnatomicalEntityDescriptor" ;
    rdfs:subClassOf gene_review:Descriptor ;
    skos:definition "A descriptor for an anatomical entity, tissue, organismal region, or structure." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:BiologicalProcessDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "BiologicalProcessDescriptor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:ends_with ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:starts_with ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:inputs ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:ends_with ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:occurs_in ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:starts_with ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:starts_with ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:inputs ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:ends_with ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:occurs_in ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:outputs ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:outputs ],
        gene_review:Descriptor ;
    skos:definition "A descriptor for a biological process, pathway, reaction, or process-like module grounding." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:CellTypeDescriptor a owl:Class,
