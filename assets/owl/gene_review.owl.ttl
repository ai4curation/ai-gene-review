gene_review:PairwiseOverlap a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "PairwiseOverlap" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:condition_b_in_sets ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:intersection_count ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:containment_a_in_b ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:intersection_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:jaccard_similarity ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:containment_b_in_a ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:a_minus_b_count ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:condition_a ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty gene_review:intersection_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:condition_b_label ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty gene_review:count_a ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:condition_a_label ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:condition_b ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:condition_a ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:count_a ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:condition_b_label ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty gene_review:a_minus_b_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:interpretation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:count_a ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:interpretation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:b_minus_a_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1e+00 ] ) ] ) ] ;
            owl:onProperty gene_review:containment_b_in_a ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:condition_b ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:b_minus_a_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:condition_b ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:condition_b_label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:protein_database ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ] ) ] ;
            owl:onProperty gene_review:condition_a_in_sets ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty gene_review:count_b ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty gene_review:b_minus_a_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:OverlapInterpretationEnum ;
            owl:onProperty gene_review:interpretation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:condition_a ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:containment_a_in_b ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:condition_a_label ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ] ) ] ;
            owl:onProperty gene_review:condition_b_in_sets ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:protein_database ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:a_minus_b_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1e+00 ] ) ] ) ] ;
            owl:onProperty gene_review:containment_a_in_b ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:condition_a_label ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:condition_a_in_sets ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:count_b ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ProteinDatabaseEnum ;
            owl:onProperty gene_review:protein_database ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:containment_b_in_a ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:jaccard_similarity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:count_b ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1e+00 ] ) ] ) ] ;
            owl:onProperty gene_review:jaccard_similarity ] ;
    skos:definition "Overlap statistics between two domain conditions (InterPro, FunFam, etc.) in the same condition set. Provides set difference metrics to measure uniqueness and redundancy." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ParsimonyAssessment a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ParsimonyAssessment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:assessment ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:SupportingTextInReference ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:assessment ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ParsimonyEnum ;
            owl:onProperty gene_review:assessment ] ;
    skos:definition "Assessment of rule parsimony (simplicity vs complexity)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:PredictedAnnotation a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "PredictedAnnotation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:source_version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:source_method ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:predicted_term ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:predicted_term ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:review ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:predicted_term_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:review ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:source_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:PredictionAssessment ;
            owl:onProperty gene_review:review ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:source_reference_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:source_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:source_method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:predicted_term ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:source_method ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:source_reference_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:source_reference_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:predicted_term_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:PredictedTermTypeEnum ;
            owl:onProperty gene_review:predicted_term_type ] ;
    skos:definition "A single computational prediction and its review. Each prediction comes from a specific method and predicts a term (EC number, GO term, etc.) for the gene." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:PredictionAssessment a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "PredictionAssessment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:assessment ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:error_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:summary ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:PredictionErrorTypeEnum ;
            owl:onProperty gene_review:error_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:confidence_score ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:summary ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:assessment ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:PredictionAssessmentEnum ;
            owl:onProperty gene_review:assessment ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:confidence_score ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:SupportingTextInReference ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 2 ] ) ] ) ] ;
            owl:onProperty gene_review:confidence_score ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:summary ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:error_type ] ;
    skos:definition "Assessment of a single computational prediction. Uses categories from de Crécy-Lagard et al. 2025 (PMID:40703034) plus extensions for GO predictions." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ProteinComplexDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ProteinComplexDescriptor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ComplexUnit ;
            owl:onProperty gene_review:active_units ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:active_units ],
        gene_review:CellularComponentDescriptor ;
    skos:definition "A descriptor for a protein-containing complex or subcomplex." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:RedundantAnnotation a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "RedundantAnnotation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:interpro_label ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:go_label ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:go_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:go_label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:go_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:interpro_source ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:interpro_label ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:interpro_source ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:interpro_label ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:go_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:interpro_source ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:go_label ] ;
    skos:definition "A GO annotation that is redundant with an existing InterPro2GO mapping" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:RelatedEntry a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "RelatedEntry" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:intersection_count ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:relationship ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:jaccard_similarity ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:EntryRelationshipEnum ;
            owl:onProperty gene_review:relationship ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1e+00 ] ) ] ) ] ;
            owl:onProperty gene_review:jaccard_similarity ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1e+00 ] ) ] ) ] ;
            owl:onProperty gene_review:containment ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:relationship ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Integer ;
            owl:onProperty gene_review:intersection_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:containment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:jaccard_similarity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:exclusive_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Integer ;
            owl:onProperty gene_review:exclusive_count ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:target_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:containment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:exclusive_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:target_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:target_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:intersection_count ] ;
    skos:definition "A relationship from this entry to another entry in the rule. Categorized as PREDICTS (this → other), PREDICTED_BY (other → this), or EQUIV (bidirectional)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:RelationDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "RelationDescriptor" ;
    rdfs:subClassOf gene_review:Descriptor ;
    skos:definition "A descriptor for a relation or connection predicate." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:RuleCondition a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "RuleCondition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:curie ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:label ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:label ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:protein_database ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:interpro_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:protein_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:uniqueness_score ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:curie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:negated ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:negated ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:protein_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Boolean ;
            owl:onProperty gene_review:negated ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:condition_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ConditionTypeEnum ;
            owl:onProperty gene_review:condition_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:curie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:protein_database ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:uniqueness_score ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty gene_review:protein_count ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:interpro_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:sample_proteins ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:sample_proteins ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ProteinDatabaseEnum ;
            owl:onProperty gene_review:protein_database ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1e+00 ] ) ] ) ] ;
            owl:onProperty gene_review:uniqueness_score ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:condition_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:InterProTypeEnum ;
            owl:onProperty gene_review:interpro_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:label ] ;
    skos:definition "A single condition in a rule antecedent" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:RuleConditionSet a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "RuleConditionSet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:number ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:number ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:PairwiseOverlap ;
            owl:onProperty gene_review:pairwise_overlap ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:pairwise_overlap ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ] ) ] ;
            owl:onProperty gene_review:number ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:conditions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:RuleCondition ;
            owl:onProperty gene_review:conditions ] ;
    skos:definition "A set of conditions that must ALL be true (conjunction/AND). Multiple condition sets in a rule are OR-ed together (disjunction)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:RuleGOAnnotation a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "RuleGOAnnotation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:go_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:go_label ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:go_label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:aspect ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:go_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:aspect ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:go_label ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:aspect ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:go_id ] ;
    skos:definition "A GO annotation produced by the rule" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:RuleReviewEntry a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "RuleReviewEntry" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( linkml:Integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ] ) ] ;
            owl:onProperty gene_review:appears_in_condition_sets ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:RelatedEntry ;
            owl:onProperty gene_review:related_entries ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:asserted_predicted_go_terms ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:source ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:EntryTypeEnum ;
            owl:onProperty gene_review:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Integer ;
            owl:onProperty gene_review:protein_count ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:label ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:asserted_predicted_go_terms ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:source ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:protein_count ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:protein_count ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:related_entries ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:appears_in_condition_sets ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:source ] ;
