gene_review:CoreFunction a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "CoreFunction" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:directly_involved_in ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:locations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:substrates ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:SupportingTextInReference ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:molecular_function ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:contributes_to_molecular_function ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:in_complex ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:molecular_function ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:molecular_function ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:anatomical_locations ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:in_complex ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:anatomical_locations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:knowledge_gaps ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:contributes_to_molecular_function ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:contributes_to_molecular_function ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:directly_involved_in ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:substrates ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:in_complex ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:locations ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:KnowledgeGap ;
            owl:onProperty gene_review:knowledge_gaps ] ;
    skos:definition "A core function is a GO-CAM-like annotation of the core evolved functions of a gene. This is a synthesis of the reviewed core annotations, brought together into a unified GO-CAM-like representation." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

