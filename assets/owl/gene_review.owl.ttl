gene_review:full_text_unavailable a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "full_text_unavailable" ;
    rdfs:range linkml:Boolean ;
    skos:definition "Whether the full text is unavailable" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:predicate a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "predicate" ;
    rdfs:range linkml:String ;
    skos:definition "Predicate of the extension" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:summary a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "summary" ;
    rdfs:range linkml:String ;
    skos:definition "Summary of the review" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:supporting_text a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "supporting_text" ;
    rdfs:range linkml:String ;
    skos:definition "Optional quote or excerpt from the evidence source.",
        "Supporting text from the publication. This should be exact substrings. Different substrings can be broken up by '...'s. These substrings will be checked against the actual text of the paper. If editorialization is necessary, put this in square brackets (this is not checked). For example, you can say '...[CFAP300 shows] transport within cilia is IFT dependent...'" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:taxon a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "taxon" ;
    rdfs:range gene_review:Term ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:term a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "term" ;
    rdfs:range gene_review:Term ;
    skos:definition "Term to be annotated" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:title a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "title" ;
    rdfs:range linkml:String ;
    skos:definition "Title of the entity" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:type a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:EvidenceItem a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "EvidenceItem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:url ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:supporting_text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:statement ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:supporting_text ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:statement ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:source_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:url ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:source_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:source_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:statement ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:supporting_text ] ;
    skos:definition "A lightweight citable source for module-level assertions. The source may be a PMID, DOI, database record, local file, pathway record, issue, or any other citable artifact. This is deliberately less strict than the publication quote validation used in gene reviews." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ReferenceRelevanceEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#HIGH> <https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#MEDIUM> <https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#LOW> <https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#NONE> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#HIGH>,
        <https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#LOW>,
        <https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#MEDIUM>,
        <https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#NONE> .

gene_review:knowledge_gaps a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "knowledge_gaps" ;
    rdfs:range gene_review:KnowledgeGap ;
    skos:definition "Curated, literature-grounded statements of what is NOT known — applicable at the level of the whole gene, a single existing annotation, a core function, a whole module, or a single module step/node. The inverse of core_functions: everywhere else the schema records what IS known; here it records, with the same evidentiary discipline, what is not. See the Function Knowledge Gaps project (projects/FUNCTION_KNOWLEDGE_GAPS.md)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:FunctionalIsoformTypeEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#SPLICE_VARIANT> <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#SPLICE_CLASS> <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#CLEAVAGE_PRODUCT> <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#MODIFICATION_STATE> <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#CONFORMATIONAL_STATE> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#CLEAVAGE_PRODUCT>,
        <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#CONFORMATIONAL_STATE>,
        <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#MODIFICATION_STATE>,
        <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#SPLICE_CLASS>,
        <https://w3id.org/ai4curation/gene_review/FunctionalIsoformTypeEnum#SPLICE_VARIANT> .

gene_review:GeneReviewStatusEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/GeneReviewStatusEnum#INITIALIZED> <https://w3id.org/ai4curation/gene_review/GeneReviewStatusEnum#IN_PROGRESS> <https://w3id.org/ai4curation/gene_review/GeneReviewStatusEnum#DRAFT> <https://w3id.org/ai4curation/gene_review/GeneReviewStatusEnum#COMPLETE> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/GeneReviewStatusEnum#COMPLETE>,
        <https://w3id.org/ai4curation/gene_review/GeneReviewStatusEnum#DRAFT>,
        <https://w3id.org/ai4curation/gene_review/GeneReviewStatusEnum#INITIALIZED>,
        <https://w3id.org/ai4curation/gene_review/GeneReviewStatusEnum#IN_PROGRESS> .

gene_review:KnowledgeGapAspectEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#MF_DARK> <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#BP_DARK> <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#CC_DARK> <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#WHOLLY_DARK> <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#RESIDUAL_SUBGAP> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#BP_DARK>,
        <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#CC_DARK>,
        <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#MF_DARK>,
        <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#RESIDUAL_SUBGAP>,
        <https://w3id.org/ai4curation/gene_review/KnowledgeGapAspectEnum#WHOLLY_DARK> .

gene_review:LiteratureSupportEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#STRONG> <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#MODERATE> <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#WEAK> <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#NONE> <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#CONTRADICTED> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#CONTRADICTED>,
        <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#MODERATE>,
        <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#NONE>,
        <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#STRONG>,
        <https://w3id.org/ai4curation/gene_review/LiteratureSupportEnum#WEAK> .

gene_review:TaxonomicScopeEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#TOO_BROAD> <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#APPROPRIATE> <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#TOO_NARROW> <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#MISSING> <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#UNNECESSARY> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#APPROPRIATE>,
        <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#MISSING>,
        <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#TOO_BROAD>,
        <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#TOO_NARROW>,
        <https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#UNNECESSARY> .

gene_review:FindingReviewStatusEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#CURRENT> <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#CORROBORATED> <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#DISPUTED> <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#OVERTURNED> <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#UNVERIFIED> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#CORROBORATED>,
        <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#CURRENT>,
        <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#DISPUTED>,
        <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#OVERTURNED>,
        <https://w3id.org/ai4curation/gene_review/FindingReviewStatusEnum#UNVERIFIED> .

gene_review:SupportingTextInReference a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "SupportingTextInReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Reference ;
            owl:onProperty gene_review:reference_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:reference_section_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:full_text_unavailable ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:supporting_text ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ManuscriptSection ;
            owl:onProperty gene_review:reference_section_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:reference_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:full_text_unavailable ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:supporting_text_fulltext ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:reference_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:supporting_text ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:Boolean ;
            owl:onProperty gene_review:full_text_unavailable ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:supporting_text_fulltext ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:reference_section_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:supporting_text ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:supporting_text_fulltext ] ;
    skos:definition "A supporting text in a reference." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:OverlapInterpretationEnum a owl:Class,
        linkml:EnumDefinition ;
