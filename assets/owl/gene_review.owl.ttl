        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/SpecificityEnum#TOO_BROAD> <https://w3id.org/ai4curation/gene_review/SpecificityEnum#APPROPRIATE> <https://w3id.org/ai4curation/gene_review/SpecificityEnum#TOO_NARROW> <https://w3id.org/ai4curation/gene_review/SpecificityEnum#MISMATCHED> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/SpecificityEnum#APPROPRIATE>,
        <https://w3id.org/ai4curation/gene_review/SpecificityEnum#MISMATCHED>,
