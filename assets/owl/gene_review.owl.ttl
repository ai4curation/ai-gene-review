    rdfs:label "ZERO_OR_MORE" ;
    rdfs:subClassOf gene_review:VariantSelectionEnum .

gene_review:active_units a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "active_units" ;
    skos:definition "Active units or role-bearing components of the complex. This is used to avoid leaving functionally important complex structure as prose." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:additional_reference_ids a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "additional_reference_ids" ;
    rdfs:range gene_review:Reference ;
    skos:definition "IDs of the references" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:aliases a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "aliases" ;
    rdfs:range linkml:String ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:alternative_products a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "alternative_products" ;
    rdfs:range gene_review:AlternativeProduct ;
    skos:definition "Alternative splicing products (isoforms) of the gene. Seeded from UniProt ALTERNATIVE PRODUCTS section. Only populated if there are multiple isoforms. Use this to document isoform-specific functions and biology. DEPRECATED: Use functional_isoforms instead for curated functional classes." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:annotons a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "annotons" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:appears_in_condition_sets a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "appears_in_condition_sets" ;
    skos:definition "Which condition sets (1-based) contain this entry (for domain conditions only)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:asserted_predicted_go_terms a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "asserted_predicted_go_terms" ;
    skos:definition "GO terms that this entry maps to via external mappings (e.g., ipr2go). Only populated for external entries not in the rule's condition sets." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:cargo a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cargo" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:cell_types a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cell_types" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:cellular_components a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cellular_components" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:cofactors a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "cofactors" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:concepts a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "concepts" ;
    skos:definition "Optional ontology/database grounding for this module node." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:condition_a_in_sets a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "condition_a_in_sets" ;
    skos:definition "List of 1-based condition set indices where condition A appears" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:condition_b_in_sets a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "condition_b_in_sets" ;
    skos:definition "List of 1-based condition set indices where condition B appears" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:condition_sets a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "condition_sets" ;
    skos:definition "List of condition sets (OR-ed together). Each condition set is a conjunction (AND) of conditions. The rule fires if ANY condition set matches." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:connections a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "connections" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:core_functions a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "core_functions" ;
    rdfs:range gene_review:CoreFunction ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:developmental_stages a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "developmental_stages" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:directly_involved_in a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "directly_involved_in" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:entries a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "entries" ;
    skos:definition "Entry-centric view of all entities in the rule (domain conditions and GO terms). Each entry tracks its relationships (PREDICTS, PREDICTED_BY, EQUIV) to other entries." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:existing_annotations a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "existing_annotations" ;
    rdfs:range gene_review:ExistingAnnotation ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:experts a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "experts" ;
    skos:definition "Experts to answer the question. These should be drawn from the authors of relevant publications already referenced. If no suitable experts are available, it's OK to leave this as an empty list!" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:extensions a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "extensions" ;
    rdfs:range gene_review:AnnotationExtension ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:findings a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "findings" ;
    rdfs:range gene_review:Finding ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:functional_isoforms a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "functional_isoforms" ;
    rdfs:range gene_review:FunctionalIsoform ;
    skos:definition "Curated functional isoform classes for the gene. Unlike alternative_products (which is seeded from UniProt), this field is purely curator/agent-defined to capture FUNCTIONALLY RELEVANT distinctions. Examples: - Splice classes that group multiple UniProt isoforms (e.g., WT1 +KTS vs -KTS) - Cleavage products from polyproteins (e.g., POMC peptides) - Modification states with distinct functions Only populate when there ARE functionally distinct forms worth documenting." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:gap_kind a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "gap_kind" ;
    skos:definition "The kind(s) of ignorance — biology, curation, and/or ontology — which determines who can resolve it. Multiple values denote a blend (e.g. a biology gap with an ontology shadow)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:go_annotations a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "go_annotations" ;
    skos:definition "GO terms assigned by this rule" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ids a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ids" ;
    skos:definition "UniProt identifiers belonging to this functional class. For UNIPROT_ISOFORM: P19544-1, P19544-2, etc. For UNIPROT_CHAIN: PRO_0000024969, PRO_0000024970, etc." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:inputs a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "inputs" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:isoform_specific_terms a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "isoform_specific_terms" ;
    skos:definition "GO terms that are specific to this functional class. These are terms that should NOT be annotated to the gene as a whole, only to this specific form. Using Term objects enables linkml-term-validator checking." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:maps_to a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "maps_to" ;
    skos:definition "Mappings to underlying UniProt identifiers. Optional - some functional classes may not map cleanly to specific UniProt IDs." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:novel_annotations a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "novel_annotations" ;
    skos:definition "GO IDs not found in InterPro2GO for any rule condition" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:occurs_in a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "occurs_in" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:outputs a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "outputs" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:pairwise_overlap a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "pairwise_overlap" ;
    skos:definition "Pairwise overlap statistics for domain conditions in this set. Only computed for InterPro, FunFam, PANTHER conditions. Provides set difference metrics (uniqueness) and Jaccard similarity." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:parts a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "parts" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:predictions a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "predictions" ;
    skos:definition "List of predictions to review" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:processes a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "processes" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:products a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "products" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:proposed_mappings a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "proposed_mappings" ;
    skos:definition "Proposed mappings to equivalent terms in other ontologies" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:proposed_new_terms a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "proposed_new_terms" ;
    rdfs:range gene_review:ProposedOntologyTerm ;
    skos:definition "Proposed new ontology terms that should exist but don't" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:proposed_terms a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "proposed_terms" ;
    skos:definition "For ONTOLOGY gaps, the new ontology term(s) that would let the knowledge be expressed (e.g. \"structural constituent of complex X\"). May elaborate the gene's top-level proposed_new_terms." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:provenance a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "provenance" ;
    skos:definition "Evidence that the unknown is REAL and not merely uncurated — ideally the field's own admissions of ignorance (\"remains to be determined\", \"the precise role is unknown\"). The supporting_text is a verbatim substring of the cited reference and is checked by the reference validator exactly like supported_by. When the only available source is a DOI-only paper or a local analysis, anchor provenance to that reference_id (e.g. a file: path)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:redundant_annotations a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "redundant_annotations" ;
    skos:definition "GO annotations that already exist in InterPro2GO" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:related_entries a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "related_entries" ;
    skos:definition "Relationships to other entries in the rule" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:representative_members a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "representative_members" ;
    skos:definition "Representative concrete members used to orient the family. These are examples, not an exhaustive member list and not a claim that the module is limited to these proteins." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:sample_proteins a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "sample_proteins" ;
    skos:definition "Sample UniProt IDs matching this condition. Only included when protein_count < 20 to avoid bloating files. Limited to max 10 examples." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:source_documents a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "source_documents" ;
    skos:definition "Paths to supporting source documents (e.g., reasoning traces, raw model outputs) for provenance" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:suggested_experiments a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "suggested_experiments" ;
    rdfs:range gene_review:Experiment ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:suggested_modifications a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "suggested_modifications" ;
    skos:definition "Specific modifications suggested if action is MODIFY" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:suggested_questions a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "suggested_questions" ;
    rdfs:range gene_review:Question ;
    skos:definition "Suggested questions to ask experts about the gene. Only include if not obvious from the literature." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:superseded_by a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "superseded_by" ;
    rdfs:range gene_review:Reference ;
    skos:definition "Reference(s) that dispute, correct, or overturn this finding. Used together with finding_status DISPUTED or OVERTURNED." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:supporting_entities a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "supporting_entities" ;
    rdfs:range linkml:String ;
    skos:definition "IDs of the supporting entities" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:tags a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "tags" ;
    rdfs:range linkml:String ;
    skos:definition "Tags associated with the gene for categorization and organization" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:targets a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "targets" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:taxa a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "taxa" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:variant_sets a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "variant_sets" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:variants a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "variants" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

IAO:0000326 a owl:Class,
        gene_review:ManuscriptSection ;
    rdfs:label "APPENDICES",
        "SUPPLEMENTARY_MATERIAL" ;
    rdfs:subClassOf gene_review:ManuscriptSection .

gene_review:GeneDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "GeneDescriptor" ;
    rdfs:subClassOf gene_review:Descriptor ;
    skos:definition "A descriptor for a gene or locus." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ModuleNode a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ModuleNode" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ModulePart ;
            owl:onProperty gene_review:parts ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:module_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ModuleConnection ;
            owl:onProperty gene_review:connections ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:label ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:variant_sets ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:concepts ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ModuleAnnoton ;
            owl:onProperty gene_review:annotons ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:EvidenceItem ;
            owl:onProperty gene_review:evidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ModuleContext ;
            owl:onProperty gene_review:context ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:KnowledgeGap ;
            owl:onProperty gene_review:knowledge_gaps ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:evidence ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ModuleTypeEnum ;
            owl:onProperty gene_review:module_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:label ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ModuleVariantSet ;
            owl:onProperty gene_review:variant_sets ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:context ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:concepts ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:parts ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:module_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:annotons ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:context ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:connections ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:knowledge_gaps ] ;
    skos:definition "A node in a module. Nodes can be recursively decomposed using parts and variant_sets, and may also carry leaf annotons and connections." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:MolecularFunctionDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "MolecularFunctionDescriptor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:source_location ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:cofactors ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:targets ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:substrates ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:cargo ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:destination_location ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:products ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:cofactors ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:cargo ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:source_location ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:targets ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:CellularComponentDescriptor ;
            owl:onProperty gene_review:destination_location ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Descriptor ;
            owl:onProperty gene_review:substrates ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:CellularComponentDescriptor ;
            owl:onProperty gene_review:source_location ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:destination_location ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:products ],
        gene_review:Descriptor ;
    skos:definition "A descriptor for a molecular function. Extra slots capture common functional nuance without requiring formal post-composition." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ProposedOntologyTerm a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ProposedOntologyTerm" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:proposed_definition ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:proposed_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:justification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:proposed_parent ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:proposed_definition ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:proposed_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:TermMapping ;
            owl:onProperty gene_review:proposed_mappings ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:proposed_parent ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:proposed_definition ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:proposed_parent ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:proposed_mappings ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:SupportingTextInReference ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:justification ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:proposed_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:justification ] ;
    skos:definition "A proposed new ontology term that should exist but doesn't currently" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:Review a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "Review" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:summary ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:summary ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:action ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ActionEnum ;
            owl:onProperty gene_review:action ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:reason ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:SupportingTextInReference ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:summary ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:proposed_replacement_terms ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:knowledge_gaps ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:reason ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:action ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Reference ;
            owl:onProperty gene_review:additional_reference_ids ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:additional_reference_ids ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:supported_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:KnowledgeGap ;
            owl:onProperty gene_review:knowledge_gaps ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Term ;
            owl:onProperty gene_review:proposed_replacement_terms ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:reason ] ;
    skos:definition "A review of an existing annotation." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:a_minus_b_count a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "a_minus_b_count" ;
    skos:definition "Number of proteins in A but not in B (|A - B|). Represents the uniqueness of A with respect to B. High value = A adds unique coverage beyond B. Zero value = A is completely contained in B (A ⊆ B)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:action_rationale a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "action_rationale" ;
    skos:definition "Rationale for the recommended action" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:aspect a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "aspect" ;
    skos:definition "GO aspect (F, P, or C)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:axis a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "axis" ;
    skos:definition "The dimension along which these variants differ, e.g. taxon, cell type, compartment, route, enzyme family." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:b_minus_a_count a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "b_minus_a_count" ;
    skos:definition "Number of proteins in B but not in A (|B - A|). Represents the uniqueness of B with respect to A. High value = B adds unique coverage beyond A. Zero value = B is completely contained in A (B ⊆ A)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:boundary a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "boundary" ;
    skos:definition "What IS firmly established, so the gap is sharply delimited. The edge of current knowledge against which the gap is defined." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:condition_a a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "condition_a" ;
    skos:definition "First condition value (e.g., IPR005982)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:condition_a_label a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "condition_a_label" ;
    skos:definition "Human-readable label for condition A" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:condition_b a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "condition_b" ;
    skos:definition "Second condition value (e.g., IPR008255)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:condition_b_label a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "condition_b_label" ;
    skos:definition "Human-readable label for condition B" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:condition_overlap a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "condition_overlap" ;
    skos:definition "Assessment of overlap between rule conditions" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:condition_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "condition_type" ;
    skos:definition "Type of condition" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:confidence a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "confidence" ;
    skos:definition "Overall confidence in the rule (0.0 to 1.0)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:confidence_score a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "confidence_score" ;
    skos:definition "Confidence score following de Crécy-Lagard et al. 2025: 2 = concordant with evidence, 1 = uncertain, 0 = discordant with evidence" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:connection_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "connection_type" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:containment a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "containment" ;
    skos:definition "Containment score (0-1) for the directional relationship. For PREDICTS: this_in_target (how much of this is contained in target). For PREDICTED_BY: target_in_this (how much of target is contained in this). For EQUIV: max of both directions." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:containment_a_in_b a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "containment_a_in_b" ;
    skos:definition "Proportion of A contained in B: |A ∩ B| / |A|. 1.0 means A is completely contained in B (A ⊆ B)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:containment_b_in_a a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "containment_b_in_a" ;
    skos:definition "Proportion of B contained in A: |A ∩ B| / |B|. 1.0 means B is completely contained in A (B ⊆ A)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:contributes_to_molecular_function a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "contributes_to_molecular_function" ;
    skos:definition "A molecular function that this gene product contributes to as part of a complex, but does not independently enable. Used for accessory/structural subunits of multi-protein complexes (e.g., an accessory subunit of Complex I contributes_to NADH dehydrogenase activity but does not have that activity on its own). The molecular_function slot should then contain the subunit-specific activity (e.g., structural molecule activity)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:correctness a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "correctness" ;
    rdfs:range gene_review:ReferenceCorrectnessEnum ;
    skos:definition "Reviewer's overall assessment of a reference's trustworthiness - both citation correctness (the identifier resolves to the intended paper that supports its use) and scientific soundness of that paper's claim." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:count_a a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "count_a" ;
    skos:definition "Number of proteins matching condition A in specified database" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:count_b a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "count_b" ;
    skos:definition "Number of proteins matching condition B in specified database" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:created_date a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "created_date" ;
    skos:definition "Date the rule was created" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:curie a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "curie" ;
    skos:definition "Normalized CURIE form (e.g., InterPro:IPR000001, NCBITaxon:4751)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:dark_aspect a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "dark_aspect" ;
    skos:definition "Which GO aspect (or pattern) is dark for this gap. Most \"dark\" genes are not uniformly dark." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:destination_location a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "destination_location" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:domain a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "domain" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ends_with a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ends_with" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:error_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "error_type" ;
    skos:definition "Type of error that led to the incorrect prediction, following Table 1 of de Crécy-Lagard et al. 2025" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:evidence_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "evidence_type" ;
    rdfs:range gene_review:EvidenceType ;
    skos:definition "Evidence code (e.g., IDA, IBA, ISS, TAS)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:exclusive_count a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "exclusive_count" ;
    skos:definition "Number of proteins exclusive to the \"source\" of the relationship. For PREDICTS: proteins in this but not target. For PREDICTED_BY: proteins in target but not this. For EQUIV: proteins in this but not target (A - B)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:experiment_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "experiment_type" ;
    skos:definition "Type of experiment or assay to answer the question" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:family a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "family" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:finding_review a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "finding_review" ;
    rdfs:range gene_review:FindingReview ;
    skos:definition "Manual reviewer assessment of this specific finding - in particular whether the finding remains current, is disputed, or has been overturned/superseded by later evidence. Reviewer-supplied; distinct from the statement/supporting_text that describe the finding itself." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:finding_status a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "finding_status" ;
    rdfs:range gene_review:FindingReviewStatusEnum ;
    skos:definition "Reviewer's assessment of the empirical standing of a specific finding in light of other evidence (e.g. whether it has been disputed or overturned)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:gap_statement a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "gap_statement" ;
    skos:definition "The specific unknown, stated precisely. Not \"role unclear\" but e.g. \"the direct substrate / the catalytic activity / the essential partner is undetermined\"." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:gene a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "gene" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:gene_product a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "gene_product" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:go_specificity a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "go_specificity" ;
    skos:definition "Assessment of GO term specificity" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:homolog_of a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "homolog_of" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:hypothesis a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "hypothesis" ;
    skos:definition "Hypothesis to be investigated" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:in_complex a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "in_complex" ;
    skos:definition "The protein-containing complex (GO:0032991 descendant) that this gene product is an active unit of. Use this — not locations — for complex membership (e.g. ribosome, spliceosome, EMC, signal peptidase complex)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:interpretation a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "interpretation" ;
    skos:definition "Automated interpretation of overlap pattern" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:interpro_label a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "interpro_label" ;
    skos:definition "InterPro domain label" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:interpro_source a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "interpro_source" ;
    skos:definition "InterPro ID that already maps to this GO term in ipr2go" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:interpro_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "interpro_type" ;
    skos:definition "InterPro entry type (family, domain, active_site, etc.). Only populated for InterPro conditions (condition_type = INTERPRO). Extracted from InterPro metadata or API." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ipr2go_redundancy a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ipr2go_redundancy" ;
    skos:definition "Analysis of redundancy with InterPro2GO mappings" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:is_invalid a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "is_invalid" ;
    rdfs:range linkml:Boolean ;
    skos:definition "Whether the reference is invalid (e.g., retracted or replaced)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:isoform a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "isoform" ;
    rdfs:range linkml:String ;
    skos:definition "UniProt isoform identifier (e.g., \"P19544-1\" for WT1 isoform 1). Only populated when the annotation is specific to a particular isoform rather than the canonical protein sequence. Note that just because an experiment used a particular isoform doesn't mean the annotation is isoform-specific - it may apply to all isoforms. Use this field only when there is clear evidence the annotation is isoform-specific." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:justification a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "justification" ;
    skos:definition "Justification for why this term is needed" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:literature_support a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "literature_support" ;
    skos:definition "Assessment of literature support for the rule" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:locus_tag a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "locus_tag" ;
    skos:definition "Locus tag for the gene (e.g., b1267 for E. coli)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:modified_date a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "modified_date" ;
    skos:definition "Date the rule was last modified" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:module a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "module" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:module_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "module_type" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:molecular_function a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "molecular_function" ;
    skos:definition "The molecular function this gene product enables (i.e., has the activity independently). For complex subunits that contribute to but don't independently have a complex-level activity, use contributes_to_molecular_function instead and put a subunit-specific MF here (e.g., structural constituent of ribosome, electron transfer activity)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:node a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "node" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:number a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "number" ;
    skos:definition "1-based condition set number (CS1, CS2, CS3, etc.)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ontology a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ontology" ;
    rdfs:range linkml:String ;
    skos:definition "Ontology of the term. E.g `go`, `cl`, `hp`" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:optional a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "optional" ;
    skos:definition "Whether this part is optional in the parent module." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:order a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "order" ;
    skos:definition "Optional display or temporal order. Equal or absent values imply partial ordering only." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:original_reference_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "original_reference_id" ;
    rdfs:range gene_review:Reference ;
    skos:definition "ID of the original reference" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:ortholog_of a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "ortholog_of" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:parsimony a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "parsimony" ;
    skos:definition "Assessment of rule parsimony (simplicity vs complexity)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:predicted_term a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "predicted_term" ;
    skos:definition "The predicted term (GO term, EC number, etc.)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:predicted_term_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "predicted_term_type" ;
    skos:definition "Type of predicted term (EC, GO_MF, GO_BP, GO_CC)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:preferred_term a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "preferred_term" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:product_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "product_type" ;
    rdfs:range gene_review:ProductTypeEnum ;
    skos:definition "Type of gene product (protein, ncRNA, etc.)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> ;
    skos:note "currently not required, assumed PROTEIN by default, but this may be explicit in future" .

gene_review:proposed_definition a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "proposed_definition" ;
    skos:definition "Proposed definition for the new term" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:proposed_name a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "proposed_name" ;
    skos:definition "Proposed name for the new term" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:proposed_parent a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "proposed_parent" ;
    skos:definition "Proposed parent term in the ontology hierarchy" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:proposed_replacement_terms a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "proposed_replacement_terms" ;
    rdfs:range gene_review:Term ;
    skos:definition "If the action is MODIFY, then this is a list of proposed replacement terms" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> ;
    skos:note "note there is a separate rule that this is required IF the action is MODIFY" .

gene_review:protein_complex a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "protein_complex" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:publication_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "publication_type" ;
    rdfs:range gene_review:PublicationTypeEnum ;
    skos:definition "The kind of publication or source this reference is (e.g. primary research article, review, meta-analysis, database record, AI deep-research report). For PMIDs this is normally inferred from the PubMed publication-type ('PT') metadata rather than set by hand; for non-PMID references (GO_REF, Reactome, file:) it is inferred from the identifier. Lets analyses ask, e.g., whether review articles or abstracts alone are sufficient to support a given annotation action." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:qualifier a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "qualifier" ;
    rdfs:range gene_review:AnnotationQualifierEnum ;
    skos:definition "The GO annotation qualifier specifying the relationship between the gene product and the term. For MF annotations, distinguishes 'enables' (gene product has the activity independently) from 'contributes_to' (gene product contributes to a complex's activity but does not have the activity alone). For BP, distinguishes 'involved_in', 'acts_upstream_of', etc. For CC, distinguishes 'located_in', 'part_of', 'is_active_in', 'colocalizes_with'." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:question a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "question" ;
    skos:definition "Question to be answered" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:reason a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "reason" ;
    rdfs:range linkml:String ;
    skos:definition "Reason for the action" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:reference_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "reference_id" ;
    rdfs:range gene_review:Reference ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:reference_review a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "reference_review" ;
    rdfs:range gene_review:ReferenceReview ;
    skos:definition "Manual reviewer assessment of this reference (relevance, and citation correctness / scientific soundness). Reviewer-supplied, distinct from the machine-fetched id/title." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:relationship a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "relationship" ;
    skos:definition "Type of relationship" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:relevance a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "relevance" ;
    rdfs:range gene_review:ReferenceRelevanceEnum ;
    skos:definition "Reviewer judgment of how relevant the reference is to the gene's function and this review." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:required_domain a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "required_domain" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:required_function a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "required_function" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:residues a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "residues" ;
    skos:definition "Residue range for cleavage products (e.g., \"138-176\" for ACTH). Only applicable for UNIPROT_CHAIN type." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:resolution a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "resolution" ;
    skos:definition "What would resolve the gap — the experiment, ontology term, or curation action. For ONTOLOGY gaps, pair with proposed_terms (or the gene's top-level proposed_new_terms)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:retired a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "retired" ;
    rdfs:range linkml:Boolean ;
    skos:definition "Whether the annotation is retired or replaced" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:review_summary a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "review_summary" ;
    skos:definition "Overall summary of the review findings" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:reviewed_protein_count a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "reviewed_protein_count" ;
    skos:definition "Number of reviewed (Swiss-Prot) proteins annotated by this rule" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:role_description a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "role_description" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:rule a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "rule" ;
    skos:definition "The embedded rule being reviewed" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:rule_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "rule_id" ;
    skos:definition "Original rule ID (e.g., ARBA00026249, UR000000070)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:rule_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "rule_type" ;
    skos:definition "Type of rule (ARBA or UniRule)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:selection a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "selection" ;
    skos:definition "How many variants may be selected in a concrete realization." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:selector_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "selector_type" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:sequence_note a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "sequence_note" ;
    rdfs:range linkml:String ;
    skos:definition "Brief note about sequence characteristics or differences" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:significance a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "significance" ;
    skos:definition "Why closing this gap matters." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:source_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "source_id" ;
    skos:definition "Identifier for the evidence source, e.g. PMID:123456, DOI:..., Reactome:R-HSA-..., MetaCyc:..., file:..." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:source_location a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "source_location" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:source_method a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "source_method" ;
    skos:definition "Name of the prediction method (e.g., DeepECTF, PANTHER_IBA, InterPro2GO, CLEAN, GloEC, MAPred, ProteinInfer)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:source_reference_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "source_reference_id" ;
    skos:definition "Reference for the prediction method or study (e.g., PMID:37820725 for the Kim et al. 2023 DeepECTF study)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:source_version a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "source_version" ;
    skos:definition "Version or date of the prediction method" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:starts_with a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "starts_with" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:stoichiometry a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "stoichiometry" ;
    skos:definition "Optional stoichiometry or copy-number statement when known." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:supporting_text_fulltext a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "supporting_text_fulltext" ;
    rdfs:range linkml:String ;
    skos:definition "Supporting text from the full-text PDF when the full text cannot be committed to the repository. This is an interim solution for cases where we have access to full text but cannot share it publicly. Unlike supporting_text, this field is not validated against cached publication text." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:target a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "target" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:target_id a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "target_id" ;
    skos:definition "ID of the related entry" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:target_term a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "target_term" ;
    skos:definition "The target term in another ontology" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:taxonomic_scope a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "taxonomic_scope" ;
    skos:definition "Assessment of taxonomic restriction appropriateness" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:uniqueness_score a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "uniqueness_score" ;
    skos:definition "Measure of domain uniqueness (0.0 to 1.0). Calculated as 1.0 - mean(containment in other domains in same condition set). High score = more unique/specific domain. Low score = broad domain that commonly co-occurs." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:unreviewed_protein_count a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "unreviewed_protein_count" ;
    skos:definition "Number of unreviewed (TrEMBL) proteins annotated by this rule" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:url a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "url" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:value a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "value" ;
    skos:definition "The condition value (e.g., IPR000001, NCBITaxon:4751)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:anatomical_locations a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:conditions a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:locations a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:substrates a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:CellularComponentDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "CellularComponentDescriptor" ;
    rdfs:subClassOf gene_review:Descriptor ;
    skos:definition "A descriptor for a cellular component, organelle, compartment, or complex location." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:FunctionalIsoformMappingTypeEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/FunctionalIsoformMappingTypeEnum#UNIPROT_ISOFORM> <https://w3id.org/ai4curation/gene_review/FunctionalIsoformMappingTypeEnum#UNIPROT_CHAIN> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/FunctionalIsoformMappingTypeEnum#UNIPROT_CHAIN>,
        <https://w3id.org/ai4curation/gene_review/FunctionalIsoformMappingTypeEnum#UNIPROT_ISOFORM> .

gene_review:RuleTypeEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/RuleTypeEnum#ARBA> <https://w3id.org/ai4curation/gene_review/RuleTypeEnum#UNIRULE> ) ;
    linkml:permissible_values <https://w3id.org/ai4curation/gene_review/RuleTypeEnum#ARBA>,
        <https://w3id.org/ai4curation/gene_review/RuleTypeEnum#UNIRULE> .

gene_review:KnowledgeGap a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "KnowledgeGap" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:boundary ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:resolution ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:significance ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:provenance ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:dark_aspect ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:SupportingTextInReference ;
            owl:onProperty gene_review:provenance ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:gap_statement ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:significance ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:boundary ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ProposedOntologyTerm ;
            owl:onProperty gene_review:proposed_terms ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:gap_statement ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:proposed_terms ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:KnowledgeGapStatusEnum ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:boundary ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:dark_aspect ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:KnowledgeGapAspectEnum ;
            owl:onProperty gene_review:dark_aspect ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:resolution ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:KnowledgeGapKindEnum ;
            owl:onProperty gene_review:gap_kind ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:gap_kind ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:gap_statement ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:resolution ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:significance ] ;
    skos:definition "A curated, literature-grounded statement of what is NOT known about a gene product, core function, module, or step — its molecular activity, mechanism, partner(s), localization, or biological role. A knowledge gap is a reviewer judgment reached by reading the primary literature, NOT a pattern in the annotations: a heavily annotated gene can hide a gaping mechanistic hole, and a sparsely annotated one can be perfectly understood and merely under-curated. Each gap is a small, defensible scholarly object with the same evidentiary discipline used for positive claims. See projects/FUNCTION_KNOWLEDGE_GAPS.md for the methodology and worked exemplars." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:context a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:function a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:gene_symbol a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "gene_symbol" ;
    rdfs:range linkml:String ;
    skos:definition "Symbol of the gene" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:go_id a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:go_label a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:intersection_count a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:jaccard_similarity a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:name a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "name" ;
    rdfs:range linkml:String ;
    skos:definition "Human-readable name for this functional class (e.g., \"+KTS isoforms\", \"ACTH/Corticotropin\", \"Bcl-xL\").",
        "Name of the entity (e.g., isoform name like Bcl-xL)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:negated a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "negated" ;
    rdfs:range linkml:Boolean ;
    skos:definition "Whether the term is negated",
        "Whether this is a negative condition (NOT)" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:participant a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:protein_count a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:protein_database a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:reference_section_type a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "reference_section_type" ;
    rdfs:range gene_review:ManuscriptSection ;
    skos:definition "Type of section in the reference (e.g., 'ABSTRACT', 'METHODS', 'RESULTS', 'DISCUSSION')" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:review a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "review" ;
    rdfs:range gene_review:Review ;
    skos:definition "Assessment of this prediction",
        "Review of the gene" ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:review_notes a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "review_notes" ;
    rdfs:range linkml:String ;
    skos:definition "Free-text note explaining the relevance/correctness judgment (e.g. what was verified, or why a citation is wrong, disputed, or low quality)." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:role a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:source a owl:ObjectProperty,
        linkml:SlotDefinition .

gene_review:statement a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "statement" ;
    rdfs:range linkml:String ;
    skos:definition "Concise statement describing an aspect of the gene",
        "The assertion this evidence supports in this module." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

gene_review:EntryRelationshipEnum a owl:Class,
