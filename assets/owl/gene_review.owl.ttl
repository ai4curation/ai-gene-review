gene_review:FunctionalIsoform a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "FunctionalIsoform" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
