            owl:onProperty gene_review:gene_product ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:homolog_of ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:DomainDescriptor ;
            owl:onProperty gene_review:domain ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:selector_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:selector_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:family ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:ortholog_of ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:evidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:MolecularFunctionDescriptor ;
            owl:onProperty gene_review:required_function ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:required_domain ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:EvidenceItem ;
            owl:onProperty gene_review:evidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:gene_product ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:GeneDescriptor ;
            owl:onProperty gene_review:homolog_of ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:DomainDescriptor ;
            owl:onProperty gene_review:required_domain ],
