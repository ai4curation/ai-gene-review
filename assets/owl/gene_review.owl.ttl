gene_review:ConditionOverlapAssessment a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ConditionOverlapAssessment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:OverlapEnum ;
            owl:onProperty gene_review:assessment ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gene_review:assessment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
