            owl:onProperty gene_review:gene ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:domain ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:homolog_of ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:GeneProductDescriptor ;
            owl:onProperty gene_review:gene_product ],
        [ a owl:Restriction ;
