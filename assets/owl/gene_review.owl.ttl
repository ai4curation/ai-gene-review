            owl:onProperty gene_review:review_notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:finding_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:Reference ;
            owl:onProperty gene_review:superseded_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:FindingReviewStatusEnum ;
            owl:onProperty gene_review:finding_status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:finding_status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:superseded_by ] ;
    skos:definition "Manual reviewer assessment of a specific finding within a reference - in particular whether it remains current, is disputed, or has been overturned/superseded by later evidence. This is finer-grained than reference_review (which assesses the whole reference); a paper may contain some findings that stand and others that are overturned. All fields optional and reviewer-supplied." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

