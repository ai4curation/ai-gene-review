        <https://w3id.org/ai4curation/gene_review/ParsimonyEnum#PARSIMONIOUS>,
        <https://w3id.org/ai4curation/gene_review/ParsimonyEnum#REDUNDANT> .

gene_review:PredictedTermTypeEnum a owl:Class,
        linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/ai4curation/gene_review/PredictedTermTypeEnum#EC> <https://w3id.org/ai4curation/gene_review/PredictedTermTypeEnum#GO_MF> <https://w3id.org/ai4curation/gene_review/PredictedTermTypeEnum#GO_BP> <https://w3id.org/ai4curation/gene_review/PredictedTermTypeEnum#GO_CC> ) ;
