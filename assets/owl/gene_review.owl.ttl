<https://w3id.org/ai4curation/gene_review/ReferenceCorrectnessEnum#LOW_QUALITY> a owl:Class,
        gene_review:ReferenceCorrectnessEnum ;
    rdfs:label "LOW_QUALITY" ;
    rdfs:subClassOf gene_review:ReferenceCorrectnessEnum .

<https://w3id.org/ai4curation/gene_review/ReferenceCorrectnessEnum#MISCITED> a owl:Class,
        gene_review:ReferenceCorrectnessEnum ;
    rdfs:label "MISCITED" ;
    rdfs:subClassOf gene_review:ReferenceCorrectnessEnum .

<https://w3id.org/ai4curation/gene_review/ReferenceCorrectnessEnum#UNVERIFIED> a owl:Class,
        gene_review:ReferenceCorrectnessEnum ;
    rdfs:label "UNVERIFIED" ;
    rdfs:subClassOf gene_review:ReferenceCorrectnessEnum .

<https://w3id.org/ai4curation/gene_review/ReferenceCorrectnessEnum#VERIFIED> a owl:Class,
        gene_review:ReferenceCorrectnessEnum ;
    rdfs:label "VERIFIED" ;
    rdfs:subClassOf gene_review:ReferenceCorrectnessEnum .

<https://w3id.org/ai4curation/gene_review/ReferenceCorrectnessEnum#WRONG_IDENTIFIER> a owl:Class,
        gene_review:ReferenceCorrectnessEnum ;
    rdfs:label "WRONG_IDENTIFIER" ;
    rdfs:subClassOf gene_review:ReferenceCorrectnessEnum .

<https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#HIGH> a owl:Class,
        gene_review:ReferenceRelevanceEnum ;
    rdfs:label "HIGH" ;
    rdfs:subClassOf gene_review:ReferenceRelevanceEnum .

<https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#LOW> a owl:Class,
        gene_review:ReferenceRelevanceEnum ;
    rdfs:label "LOW" ;
    rdfs:subClassOf gene_review:ReferenceRelevanceEnum .

<https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#MEDIUM> a owl:Class,
        gene_review:ReferenceRelevanceEnum ;
    rdfs:label "MEDIUM" ;
    rdfs:subClassOf gene_review:ReferenceRelevanceEnum .

<https://w3id.org/ai4curation/gene_review/ReferenceRelevanceEnum#NONE> a owl:Class,
        gene_review:ReferenceRelevanceEnum ;
    rdfs:label "NONE" ;
    rdfs:subClassOf gene_review:ReferenceRelevanceEnum .

gene_review:ReferenceReview a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "ReferenceReview" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:review_notes ],
        [ a owl:Restriction ;
            owl:allValuesFrom linkml:String ;
            owl:onProperty gene_review:review_notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:correctness ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:relevance ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:correctness ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ReferenceCorrectnessEnum ;
            owl:onProperty gene_review:correctness ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gene_review:relevance ],
        [ a owl:Restriction ;
            owl:allValuesFrom gene_review:ReferenceRelevanceEnum ;
            owl:onProperty gene_review:relevance ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gene_review:review_notes ] ;
    skos:definition "Manual reviewer assessment of a reference - how relevant it is to the gene's function, and whether it is correctly cited and scientifically sound. Distinct from the machine-fetched id/title fields; all fields are optional and reviewer-supplied." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

<https://w3id.org/ai4curation/gene_review/RuleActionEnum#ACCEPT> a owl:Class,
        gene_review:RuleActionEnum ;
    rdfs:label "ACCEPT" ;
    rdfs:subClassOf gene_review:RuleActionEnum .

<https://w3id.org/ai4curation/gene_review/RuleActionEnum#DEPRECATE> a owl:Class,
        gene_review:RuleActionEnum ;
    rdfs:label "DEPRECATE" ;
    rdfs:subClassOf gene_review:RuleActionEnum .

<https://w3id.org/ai4curation/gene_review/RuleActionEnum#MERGE> a owl:Class,
        gene_review:RuleActionEnum ;
    rdfs:label "MERGE" ;
    rdfs:subClassOf gene_review:RuleActionEnum .

<https://w3id.org/ai4curation/gene_review/RuleActionEnum#MODIFY> a owl:Class,
        gene_review:RuleActionEnum ;
    rdfs:label "MODIFY" ;
    rdfs:subClassOf gene_review:RuleActionEnum .

<https://w3id.org/ai4curation/gene_review/RuleActionEnum#SPLIT> a owl:Class,
        gene_review:RuleActionEnum ;
    rdfs:label "SPLIT" ;
    rdfs:subClassOf gene_review:RuleActionEnum .

<https://w3id.org/ai4curation/gene_review/RuleActionEnum#UNDECIDED> a owl:Class,
        gene_review:RuleActionEnum ;
    rdfs:label "UNDECIDED" ;
    rdfs:subClassOf gene_review:RuleActionEnum .

<https://w3id.org/ai4curation/gene_review/RuleReviewStatusEnum#COMPLETE> a owl:Class,
        gene_review:RuleReviewStatusEnum ;
    rdfs:label "COMPLETE" ;
    rdfs:subClassOf gene_review:RuleReviewStatusEnum .

<https://w3id.org/ai4curation/gene_review/RuleReviewStatusEnum#IN_PROGRESS> a owl:Class,
        gene_review:RuleReviewStatusEnum ;
    rdfs:label "IN_PROGRESS" ;
    rdfs:subClassOf gene_review:RuleReviewStatusEnum .

<https://w3id.org/ai4curation/gene_review/RuleReviewStatusEnum#PENDING> a owl:Class,
        gene_review:RuleReviewStatusEnum ;
    rdfs:label "PENDING" ;
    rdfs:subClassOf gene_review:RuleReviewStatusEnum .

<https://w3id.org/ai4curation/gene_review/RuleTypeEnum#ARBA> a owl:Class,
        gene_review:RuleTypeEnum ;
    rdfs:label "ARBA" ;
    rdfs:subClassOf gene_review:RuleTypeEnum .

<https://w3id.org/ai4curation/gene_review/RuleTypeEnum#UNIRULE> a owl:Class,
        gene_review:RuleTypeEnum ;
    rdfs:label "UNIRULE" ;
    rdfs:subClassOf gene_review:RuleTypeEnum .

<https://w3id.org/ai4curation/gene_review/SpecificityEnum#APPROPRIATE> a owl:Class,
        gene_review:SpecificityEnum ;
    rdfs:label "APPROPRIATE" ;
    rdfs:subClassOf gene_review:SpecificityEnum .

<https://w3id.org/ai4curation/gene_review/SpecificityEnum#MISMATCHED> a owl:Class,
        gene_review:SpecificityEnum ;
    rdfs:label "MISMATCHED" ;
    rdfs:subClassOf gene_review:SpecificityEnum .

<https://w3id.org/ai4curation/gene_review/SpecificityEnum#TOO_BROAD> a owl:Class,
        gene_review:SpecificityEnum ;
    rdfs:label "TOO_BROAD" ;
    rdfs:subClassOf gene_review:SpecificityEnum .

<https://w3id.org/ai4curation/gene_review/SpecificityEnum#TOO_NARROW> a owl:Class,
        gene_review:SpecificityEnum ;
    rdfs:label "TOO_NARROW" ;
    rdfs:subClassOf gene_review:SpecificityEnum .

gene_review:TaxonDescriptor a owl:Class,
        linkml:ClassDefinition ;
    rdfs:label "TaxonDescriptor" ;
    rdfs:subClassOf gene_review:Descriptor ;
    skos:definition "A descriptor for a taxon or taxonomic scope." ;
    skos:inScheme <https://ai4curation.io/ai-gene-review> .

<https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#APPROPRIATE> a owl:Class,
        gene_review:TaxonomicScopeEnum ;
    rdfs:label "APPROPRIATE" ;
    rdfs:subClassOf gene_review:TaxonomicScopeEnum .

<https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#MISSING> a owl:Class,
        gene_review:TaxonomicScopeEnum ;
    rdfs:label "MISSING" ;
    rdfs:subClassOf gene_review:TaxonomicScopeEnum .

<https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#TOO_BROAD> a owl:Class,
        gene_review:TaxonomicScopeEnum ;
    rdfs:label "TOO_BROAD" ;
    rdfs:subClassOf gene_review:TaxonomicScopeEnum .

<https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#TOO_NARROW> a owl:Class,
        gene_review:TaxonomicScopeEnum ;
    rdfs:label "TOO_NARROW" ;
    rdfs:subClassOf gene_review:TaxonomicScopeEnum .

<https://w3id.org/ai4curation/gene_review/TaxonomicScopeEnum#UNNECESSARY> a owl:Class,
        gene_review:TaxonomicScopeEnum ;
    rdfs:label "UNNECESSARY" ;
    rdfs:subClassOf gene_review:TaxonomicScopeEnum .

<https://w3id.org/ai4curation/gene_review/VariantSelectionEnum#EXACTLY_ONE> a owl:Class,
        gene_review:VariantSelectionEnum ;
    rdfs:label "EXACTLY_ONE" ;
    rdfs:subClassOf gene_review:VariantSelectionEnum .

<https://w3id.org/ai4curation/gene_review/VariantSelectionEnum#ONE_OR_MORE> a owl:Class,
        gene_review:VariantSelectionEnum ;
    rdfs:label "ONE_OR_MORE" ;
    rdfs:subClassOf gene_review:VariantSelectionEnum .

<https://w3id.org/ai4curation/gene_review/VariantSelectionEnum#ZERO_OR_MORE> a owl:Class,
