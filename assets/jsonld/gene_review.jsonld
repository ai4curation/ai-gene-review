    },
    {
      "name": "knowledgeGap__provenance",
      "description": "Evidence that the unknown is REAL and not merely uncurated \u2014 ideally the field's own admissions of ignorance (\"remains to be determined\", \"the precise role is unknown\"). The supporting_text is a verbatim substring of the cited reference and is checked by the reference validator exactly like supported_by. When the only available source is a DOI-only paper or a local analysis, anchor provenance to that reference_id (e.g. a file: path).",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slot_uri": "https://w3id.org/ai4curation/gene_review/provenance",
