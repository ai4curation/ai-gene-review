      "name": "supported_by",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/supported_by",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slot_uri": "https://w3id.org/ai4curation/gene_review/supported_by",
      "owner": "Review",
      "domain_of": [
        "Review"
      ],
      "range": "SupportingTextInReference",
      "recommended": true,
      "multivalued": true,
      "inlined": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "summary",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/summary",
      "description": "Summary of the review",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slot_uri": "https://w3id.org/ai4curation/gene_review/summary",
      "owner": "Review",
      "domain_of": [
        "Review"
      ],
      "range": "string",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "supporting_text",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/supporting_text",
      "implements": [
        "oa:exact"
      ],
      "description": "Supporting text from the publication. This should be exact substrings. Different substrings can be broken up by '...'s. These substrings will be checked against the actual text of the paper. If editorialization is necessary, put this in square brackets (this is not checked). For example, you can say '...[CFAP300 shows] transport within cilia is IFT dependent...'",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slot_uri": "https://w3id.org/ai4curation/gene_review/supporting_text",
      "owner": "SupportingTextInReference",
      "domain_of": [
        "Finding",
        "SupportingTextInReference"
      ],
      "range": "string",
      "recommended": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "supporting_text_fulltext",
