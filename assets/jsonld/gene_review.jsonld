      "@type": "SlotDefinition"
    },
    {
      "name": "pairwiseOverlap__jaccard_similarity",
      "description": "Jaccard similarity coefficient: |A \u2229 B| / |A \u222a B| = intersection / (count_a + count_b - intersection). 0.0 = no overlap, 1.0 = complete overlap.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slot_uri": "https://w3id.org/ai4curation/gene_review/jaccard_similarity",
