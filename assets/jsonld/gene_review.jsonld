  "classes": [
    {
      "name": "GeneReview",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/GeneReview",
      "description": "Complete review for a gene",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "id",
        "gene_symbol",
        "product_type",
        "aliases",
        "tags",
        "status",
        "GeneReview_description",
        "taxon",
        "alternative_products",
        "functional_isoforms",
        "references",
        "existing_annotations",
        "core_functions",
        "proposed_new_terms",
        "suggested_questions",
        "suggested_experiments",
        "knowledge_gaps"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/GeneReview",
      "tree_root": true,
      "@type": "ClassDefinition"
    },
    {
      "name": "AlternativeProduct",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/AlternativeProduct",
      "description": "An alternative splicing product (isoform) of the gene. Corresponds to UniProt isoform entries. Use this to document isoform-specific functions where different isoforms have distinct or even antagonistic biological activities. DEPRECATED: Use FunctionalIsoform instead for curated functional classes.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "AlternativeProduct_id",
        "AlternativeProduct_name",
        "AlternativeProduct_sequence_note",
        "AlternativeProduct_description"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/AlternativeProduct",
      "@type": "ClassDefinition"
    },
    {
      "name": "FunctionalIsoform",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/FunctionalIsoform",
      "description": "A curated functional isoform class. Unlike AlternativeProduct (which maps 1:1 to UniProt isoforms), this captures FUNCTIONALLY RELEVANT distinctions that may: - Group multiple UniProt isoforms into a functional class (e.g., WT1 +KTS isoforms) - Represent cleavage products from polyproteins (e.g., POMC peptides) - Describe modification states or conformational variants Only create entries when there ARE functionally distinct forms worth documenting.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "functionalIsoform__id",
        "functionalIsoform__name",
        "functionalIsoform__type",
        "functionalIsoform__maps_to",
        "functionalIsoform__description",
        "functionalIsoform__isoform_specific_terms"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "id",
          "description": "Curator-defined identifier for this functional class. Use a descriptive format like GENE_CLASS (e.g., WT1_PLUS_KTS, POMC_ACTH, BCL2L1_XL).",
          "identifier": true,
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "name",
          "description": "Human-readable name for this functional class (e.g., \"+KTS isoforms\", \"ACTH/Corticotropin\", \"Bcl-xL\").",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "type",
          "description": "Type of functional distinction (SPLICE_VARIANT, SPLICE_CLASS, CLEAVAGE_PRODUCT, MODIFICATION_STATE, CONFORMATIONAL_STATE).",
          "range": "FunctionalIsoformTypeEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "maps_to",
          "description": "Mappings to underlying UniProt identifiers. Optional - some functional classes may not map cleanly to specific UniProt IDs.",
          "range": "FunctionalIsoformMapping",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "description",
          "description": "Detailed description of this functional class. Document the specific functions, how they differ from other classes, tissue specificity, and any antagonistic relationships (e.g., \"OREXIGENIC - opposite to alpha-MSH\").",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "isoform_specific_terms",
          "description": "GO terms that are specific to this functional class. These are terms that should NOT be annotated to the gene as a whole, only to this specific form. Using Term objects enables linkml-term-validator checking.",
          "range": "Term",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/FunctionalIsoform",
      "@type": "ClassDefinition"
    },
    {
      "name": "FunctionalIsoformMapping",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/FunctionalIsoformMapping",
      "description": "A mapping from a functional isoform class to underlying UniProt identifiers. Allows grouping multiple UniProt isoforms or chains into a single functional class.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "functionalIsoformMapping__type",
        "functionalIsoformMapping__ids",
        "functionalIsoformMapping__residues"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "type",
          "description": "Type of identifier (UNIPROT_ISOFORM or UNIPROT_CHAIN)",
          "range": "FunctionalIsoformMappingTypeEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "ids",
          "description": "UniProt identifiers belonging to this functional class. For UNIPROT_ISOFORM: P19544-1, P19544-2, etc. For UNIPROT_CHAIN: PRO_0000024969, PRO_0000024970, etc.",
          "range": "string",
          "required": true,
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "residues",
          "description": "Residue range for cleavage products (e.g., \"138-176\" for ACTH). Only applicable for UNIPROT_CHAIN type.",
          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/FunctionalIsoformMapping",
      "@type": "ClassDefinition"
    },
    {
      "name": "Term",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/Term",
      "description": "A term in a specific ontology",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "Term_id",
        "Term_label",
        "description",
        "ontology"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/Term",
      "@type": "ClassDefinition"
    },
    {
      "name": "Reference",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/Reference",
      "description": "A reference is a published text  that describes a finding or a method. References might be formal publications (where the ID is a PMID), or for methods, a GO_REF. Additionally, a reference to a local ad-hoc analysis or review can be made by using the `file:` prefix.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "Reference_id",
        "title",
        "findings",
        "is_invalid",
        "publication_type",
        "full_text_unavailable",
        "reference_review"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/Reference",
      "@type": "ClassDefinition"
    },
    {
      "name": "ReferenceReview",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/ReferenceReview",
      "description": "Manual reviewer assessment of a reference - how relevant it is to the gene's function, and whether it is correctly cited and scientifically sound. Distinct from the machine-fetched id/title fields; all fields are optional and reviewer-supplied.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "relevance",
        "correctness",
        "review_notes"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/ReferenceReview",
      "@type": "ClassDefinition"
    },
    {
      "name": "Finding",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/Finding",
      "description": "A finding is a statement about a gene, which is supported by a reference. Similar to \"comments\" in uniprot",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "statement",
        "supporting_text",
        "full_text_unavailable",
        "reference_section_type",
        "finding_review"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/Finding",
      "@type": "ClassDefinition"
    },
    {
      "name": "FindingReview",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/FindingReview",
      "description": "Manual reviewer assessment of a specific finding within a reference - in particular whether it remains current, is disputed, or has been overturned/superseded by later evidence. This is finer-grained than reference_review (which assesses the whole reference); a paper may contain some findings that stand and others that are overturned. All fields optional and reviewer-supplied.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "finding_status",
        "superseded_by",
        "review_notes"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/FindingReview",
      "@type": "ClassDefinition"
    },
    {
      "name": "SupportingTextInReference",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/SupportingTextInReference",
      "description": "A supporting text in a reference.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "reference_id",
        "supporting_text",
        "supporting_text_fulltext",
        "full_text_unavailable",
        "reference_section_type"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/SupportingTextInReference",
      "@type": "ClassDefinition"
    },
    {
      "name": "EvidenceItem",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/EvidenceItem",
      "description": "A lightweight citable source for module-level assertions. The source may be a PMID, DOI, database record, local file, pathway record, issue, or any other citable artifact. This is deliberately less strict than the publication quote validation used in gene reviews.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "evidenceItem__source_id",
        "evidenceItem__title",
        "evidenceItem__statement",
        "evidenceItem__supporting_text",
        "evidenceItem__url",
        "evidenceItem__notes"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "source_id",
          "description": "Identifier for the evidence source, e.g. PMID:123456, DOI:..., Reactome:R-HSA-..., MetaCyc:..., file:...",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "title",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "statement",
          "description": "The assertion this evidence supports in this module.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "supporting_text",
          "description": "Optional quote or excerpt from the evidence source.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "url",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "notes",
          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/EvidenceItem",
      "@type": "ClassDefinition"
    },
    {
