    {
      "name": "pairwiseOverlap__a_minus_b_count",
      "description": "Number of proteins in A but not in B (|A - B|). Represents the uniqueness of A with respect to B. High value = A adds unique coverage beyond B. Zero value = A is completely contained in B (A \u2286 B).",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slot_uri": "https://w3id.org/ai4curation/gene_review/a_minus_b_count",
