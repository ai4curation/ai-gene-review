    {
      "name": "PredictionReview",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/PredictionReview",
      "description": "Review of computational/ML predictions for a gene that are NOT in the curated GOA/UniProt annotations. This captures predictions from methods like DeepECTF, PANTHER/IBA, InterPro2GO, CLEAN, GloEC, MAPred, etc. and evaluates them against literature and bioinformatic evidence. Inspired by the systematic evaluation in de Cr\u00e9cy-Lagard et al. 2025 (PMID:40703034).",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "PredictionReview_id",
        "gene_symbol",
        "taxon",
        "PredictionReview_description",
        "references",
        "status",
        "predictionReview__locus_tag",
        "predictionReview__source_documents",
        "predictionReview__predictions"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "locus_tag",
          "description": "Locus tag for the gene (e.g., b1267 for E. coli)",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "source_documents",
          "description": "Paths to supporting source documents (e.g., reasoning traces, raw model outputs) for provenance",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "predictions",
          "description": "List of predictions to review",
          "range": "PredictedAnnotation",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/PredictionReview",
      "@type": "ClassDefinition"
    },
    {
      "name": "PredictedAnnotation",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/PredictedAnnotation",
      "description": "A single computational prediction and its review. Each prediction comes from a specific method and predicts a term (EC number, GO term, etc.) for the gene.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "predictedAnnotation__source_method",
        "predictedAnnotation__source_version",
        "predictedAnnotation__source_reference_id",
        "predictedAnnotation__predicted_term",
        "predictedAnnotation__predicted_term_type",
        "predictedAnnotation__review"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "source_method",
          "description": "Name of the prediction method (e.g., DeepECTF, PANTHER_IBA, InterPro2GO, CLEAN, GloEC, MAPred, ProteinInfer)",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "source_version",
          "description": "Version or date of the prediction method",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "source_reference_id",
          "description": "Reference for the prediction method or study (e.g., PMID:37820725 for the Kim et al. 2023 DeepECTF study)",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "predicted_term",
          "description": "The predicted term (GO term, EC number, etc.)",
          "range": "Term",
          "required": true,
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "predicted_term_type",
          "description": "Type of predicted term (EC, GO_MF, GO_BP, GO_CC)",
          "range": "PredictedTermTypeEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "review",
          "description": "Assessment of this prediction",
          "range": "PredictionAssessment",
          "required": true,
          "inlined": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/PredictedAnnotation",
      "@type": "ClassDefinition"
    },
    {
      "name": "PredictionAssessment",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/PredictionAssessment",
      "description": "Assessment of a single computational prediction. Uses categories from de Cr\u00e9cy-Lagard et al. 2025 (PMID:40703034) plus extensions for GO predictions.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "predictionAssessment__assessment",
        "predictionAssessment__confidence_score",
        "predictionAssessment__error_type",
        "predictionAssessment__summary",
        "predictionAssessment__supported_by"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "assessment",
          "description": "Assessment category for this prediction",
          "range": "PredictionAssessmentEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "confidence_score",
          "description": "Confidence score following de Cr\u00e9cy-Lagard et al. 2025: 2 = concordant with evidence, 1 = uncertain, 0 = discordant with evidence",
          "range": "integer",
          "required": true,
          "minimum_value": 0,
          "maximum_value": 2,
          "@type": "SlotDefinition"
        },
        {
          "name": "error_type",
          "description": "Type of error that led to the incorrect prediction, following Table 1 of de Cr\u00e9cy-Lagard et al. 2025",
          "range": "PredictionErrorTypeEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "summary",
          "description": "Summary of the assessment rationale",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "supported_by",
          "description": "Supporting evidence for the assessment",
          "range": "SupportingTextInReference",
          "multivalued": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/PredictionAssessment",
      "@type": "ClassDefinition"
    }
