    {
      "name": "ModuleReview",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/ModuleReview",
      "description": "Review or curation record for a recursively decomposable biological module. This can describe a pathway, organelle lifecycle, protein complex, molecular function, developmental process, or abstract/evolutionary functional plan.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "id",
        "title",
        "description",
        "references",
        "knowledge_gaps",
        "moduleReview__status",
        "moduleReview__module",
        "moduleReview__evidence",
        "moduleReview__notes"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "status",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "module",
          "range": "ModuleNode",
          "required": true,
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "evidence",
          "range": "EvidenceItem",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "notes",
          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/ModuleReview",
      "tree_root": true,
      "@type": "ClassDefinition"
    },
    {
      "name": "ModuleNode",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/ModuleNode",
      "description": "A node in a module. Nodes can be recursively decomposed using parts and variant_sets, and may also carry leaf annotons and connections.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "knowledge_gaps",
        "moduleNode__id",
        "moduleNode__label",
        "moduleNode__module_type",
        "moduleNode__description",
        "moduleNode__concepts",
        "moduleNode__context",
        "moduleNode__annotons",
        "moduleNode__parts",
        "moduleNode__variant_sets",
        "moduleNode__connections",
        "moduleNode__evidence",
        "moduleNode__notes"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "id",
          "identifier": true,
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "label",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "module_type",
          "range": "ModuleTypeEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "description",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "concepts",
          "description": "Optional ontology/database grounding for this module node.",
          "range": "Descriptor",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "context",
          "range": "ModuleContext",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "annotons",
          "range": "ModuleAnnoton",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "parts",
          "range": "ModulePart",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "variant_sets",
          "range": "ModuleVariantSet",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "connections",
          "range": "ModuleConnection",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "evidence",
          "range": "EvidenceItem",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "notes",
          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/ModuleNode",
      "@type": "ClassDefinition"
    },
    {
      "name": "ModulePart",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/ModulePart",
      "description": "A conjunctive part or step of a module node.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "modulePart__order",
        "modulePart__role",
        "modulePart__optional",
        "modulePart__node",
        "modulePart__evidence",
        "modulePart__notes"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "order",
          "description": "Optional display or temporal order. Equal or absent values imply partial ordering only.",
          "range": "integer",
          "@type": "SlotDefinition"
        },
        {
          "name": "role",
          "description": "Curator-supplied role of this part within the parent module.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "optional",
          "description": "Whether this part is optional in the parent module.",
          "range": "boolean",
          "@type": "SlotDefinition"
        },
        {
          "name": "node",
          "range": "ModuleNode",
          "required": true,
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "evidence",
          "range": "EvidenceItem",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "notes",
          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/ModulePart",
      "@type": "ClassDefinition"
    },
    {
      "name": "ModuleVariantSet",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/ModuleVariantSet",
      "description": "A set of alternative implementations for a module node or part. Variants may themselves contain parts, annotons, connections, and nested variant sets.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "moduleVariantSet__id",
        "moduleVariantSet__label",
        "moduleVariantSet__axis",
        "moduleVariantSet__selection",
        "moduleVariantSet__variants",
        "moduleVariantSet__evidence",
        "moduleVariantSet__notes"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "id",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "label",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "axis",
          "description": "The dimension along which these variants differ, e.g. taxon, cell type, compartment, route, enzyme family.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "selection",
          "description": "How many variants may be selected in a concrete realization.",
          "range": "VariantSelectionEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "variants",
          "range": "ModuleNode",
          "required": true,
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "evidence",
          "range": "EvidenceItem",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "notes",
