    {
      "name": "ExistingAnnotation",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/ExistingAnnotation",
      "description": "An existing annotation from the GO database, plus a review of the annotation.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "term",
        "qualifier",
        "extensions",
        "negated",
        "evidence_type",
        "original_reference_id",
        "retired",
        "isoform",
        "supporting_entities",
        "review"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/ExistingAnnotation",
      "@type": "ClassDefinition"
    },
    {
      "name": "Review",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/Review",
      "description": "A review of an existing annotation.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "summary",
        "action",
        "reason",
        "proposed_replacement_terms",
        "additional_reference_ids",
        "supported_by",
        "knowledge_gaps"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/Review",
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "action",
                "equals_string": "MODIFY",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "proposed_replacement_terms",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "CoreFunction",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/CoreFunction",
      "description": "A core function is a GO-CAM-like annotation of the core evolved functions of a gene. This is a synthesis of the reviewed core annotations, brought together into a unified GO-CAM-like representation.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "knowledge_gaps",
        "coreFunction__description",
        "coreFunction__supported_by",
        "coreFunction__molecular_function",
        "coreFunction__contributes_to_molecular_function",
        "coreFunction__directly_involved_in",
        "coreFunction__locations",
        "coreFunction__anatomical_locations",
        "coreFunction__substrates",
        "coreFunction__in_complex",
        "CoreFunction_description"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "description",
          "description": "Description of the core function",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "supported_by",
          "range": "SupportingTextInReference",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "molecular_function",
          "description": "The molecular function this gene product enables (i.e., has the activity independently). For complex subunits that contribute to but don't independently have a complex-level activity, use contributes_to_molecular_function instead and put a subunit-specific MF here (e.g., structural constituent of ribosome, electron transfer activity).",
          "range": "Term",
          "bindings": [
            {
              "range": "GOMolecularActivityEnum",
              "obligation_level": {
                "text": "REQUIRED",
                "description": "The metadata element is required to be present in the model",
                "@type": "PermissibleValue"
              },
              "binds_value_of": "id",
              "@type": "EnumBinding"
            }
          ],
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "contributes_to_molecular_function",
          "description": "A molecular function that this gene product contributes to as part of a complex, but does not independently enable. Used for accessory/structural subunits of multi-protein complexes (e.g., an accessory subunit of Complex I contributes_to NADH dehydrogenase activity but does not have that activity on its own). The molecular_function slot should then contain the subunit-specific activity (e.g., structural molecule activity).",
          "range": "Term",
          "bindings": [
            {
              "range": "GOMolecularActivityEnum",
              "obligation_level": {
                "text": "REQUIRED",
                "description": "The metadata element is required to be present in the model",
                "@type": "PermissibleValue"
              },
              "binds_value_of": "id",
              "@type": "EnumBinding"
            }
          ],
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "directly_involved_in",
          "range": "Term",
          "bindings": [
            {
              "range": "GOBiologicalProcessEnum",
              "obligation_level": {
                "text": "REQUIRED",
                "description": "The metadata element is required to be present in the model",
                "@type": "PermissibleValue"
              },
              "binds_value_of": "id",
              "@type": "EnumBinding"
            }
          ],
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "locations",
          "description": "Cellular anatomical entities (e.g. membranes, nucleus, cytosol, organelle parts) where the gene product functions. Do NOT use this for protein-containing complexes (GO:0032991 and its descendants) \u2014 record complex membership in in_complex instead.",
          "range": "Term",
          "bindings": [
            {
              "range": "GOCellularLocationEnum",
              "obligation_level": {
                "text": "REQUIRED",
                "description": "The metadata element is required to be present in the model",
                "@type": "PermissibleValue"
              },
              "binds_value_of": "id",
              "@type": "EnumBinding"
            }
          ],
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "anatomical_locations",
          "range": "Term",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "substrates",
          "range": "Term",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "in_complex",
          "description": "The protein-containing complex (GO:0032991 descendant) that this gene product is an active unit of. Use this \u2014 not locations \u2014 for complex membership (e.g. ribosome, spliceosome, EMC, signal peptidase complex).",
          "range": "Term",
          "bindings": [
            {
              "range": "GOProteinContainingComplexEnum",
              "obligation_level": {
                "text": "REQUIRED",
                "description": "The metadata element is required to be present in the model",
                "@type": "PermissibleValue"
              },
              "binds_value_of": "id",
              "@type": "EnumBinding"
            }
          ],
          "inlined": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/CoreFunction",
      "@type": "ClassDefinition"
    },
    {
      "name": "AnnotationExtension",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/AnnotationExtension",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "AnnotationExtension_predicate",
        "term"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/ai4curation/gene_review/AnnotationExtension",
      "@type": "ClassDefinition"
    },
    {
      "name": "TermMapping",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/TermMapping",
      "description": "A mapping between the proposed term and an equivalent term in another ontology",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "termMapping__predicate",
        "termMapping__target_term"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "predicate",
          "description": "Mapping predicate (e.g., 'skos:exactMatch', 'skos:closeMatch', 'skos:broadMatch', 'skos:narrowMatch')",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "target_term",
          "description": "The target term in another ontology",
          "range": "Term",
          "required": true,
          "inlined": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/TermMapping",
      "@type": "ClassDefinition"
    },
    {
      "name": "ProposedOntologyTerm",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/ProposedOntologyTerm",
      "description": "A proposed new ontology term that should exist but doesn't currently",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "proposedOntologyTerm__proposed_name",
        "proposedOntologyTerm__proposed_definition",
        "proposedOntologyTerm__justification",
        "proposedOntologyTerm__proposed_parent",
        "proposedOntologyTerm__proposed_mappings",
        "proposedOntologyTerm__supported_by"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "proposed_name",
          "description": "Proposed name for the new term",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "proposed_definition",
          "description": "Proposed definition for the new term",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "justification",
          "description": "Justification for why this term is needed",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "proposed_parent",
          "description": "Proposed parent term in the ontology hierarchy",
          "range": "Term",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "proposed_mappings",
          "description": "Proposed mappings to equivalent terms in other ontologies",
          "range": "TermMapping",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "supported_by",
          "range": "SupportingTextInReference",
          "multivalued": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/ProposedOntologyTerm",
      "@type": "ClassDefinition"
    },
    {
      "name": "KnowledgeGap",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/KnowledgeGap",
      "description": "A curated, literature-grounded statement of what is NOT known about a gene product, core function, module, or step \u2014 its molecular activity, mechanism, partner(s), localization, or biological role. A knowledge gap is a reviewer judgment reached by reading the primary literature, NOT a pattern in the annotations: a heavily annotated gene can hide a gaping mechanistic hole, and a sparsely annotated one can be perfectly understood and merely under-curated. Each gap is a small, defensible scholarly object with the same evidentiary discipline used for positive claims. See projects/FUNCTION_KNOWLEDGE_GAPS.md for the methodology and worked exemplars.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "knowledgeGap__gap_statement",
        "knowledgeGap__boundary",
        "knowledgeGap__gap_kind",
        "knowledgeGap__dark_aspect",
        "knowledgeGap__status",
        "knowledgeGap__significance",
        "knowledgeGap__resolution",
        "knowledgeGap__provenance",
        "knowledgeGap__proposed_terms"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "gap_statement",
          "description": "The specific unknown, stated precisely. Not \"role unclear\" but e.g. \"the direct substrate / the catalytic activity / the essential partner is undetermined\".",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "boundary",
          "description": "What IS firmly established, so the gap is sharply delimited. The edge of current knowledge against which the gap is defined.",
          "range": "string",
          "recommended": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "gap_kind",
          "description": "The kind(s) of ignorance \u2014 biology, curation, and/or ontology \u2014 which determines who can resolve it. Multiple values denote a blend (e.g. a biology gap with an ontology shadow).",
          "range": "KnowledgeGapKindEnum",
          "recommended": true,
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "dark_aspect",
          "description": "Which GO aspect (or pattern) is dark for this gap. Most \"dark\" genes are not uniformly dark.",
          "range": "KnowledgeGapAspectEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "status",
          "description": "Lifecycle status of the gap, tracking progress toward resolution.",
          "range": "KnowledgeGapStatusEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "significance",
          "description": "Why closing this gap matters.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "resolution",
          "description": "What would resolve the gap \u2014 the experiment, ontology term, or curation action. For ONTOLOGY gaps, pair with proposed_terms (or the gene's top-level proposed_new_terms).",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "provenance",
          "description": "Evidence that the unknown is REAL and not merely uncurated \u2014 ideally the field's own admissions of ignorance (\"remains to be determined\", \"the precise role is unknown\"). The supporting_text is a verbatim substring of the cited reference and is checked by the reference validator exactly like supported_by. When the only available source is a DOI-only paper or a local analysis, anchor provenance to that reference_id (e.g. a file: path).",
          "range": "SupportingTextInReference",
          "recommended": true,
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "proposed_terms",
          "description": "For ONTOLOGY gaps, the new ontology term(s) that would let the knowledge be expressed (e.g. \"structural constituent of complex X\"). May elaborate the gene's top-level proposed_new_terms.",
          "range": "ProposedOntologyTerm",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/KnowledgeGap",
      "@type": "ClassDefinition"
    },
    {
      "name": "Experiment",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/Experiment",
      "description": "A suggested experiment to answer a question about the gene",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "experiment__hypothesis",
        "experiment__description",
        "experiment__experiment_type"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "hypothesis",
          "description": "Hypothesis to be investigated",
          "range": "string",
          "recommended": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "description",
          "description": "Detailed description of the experiment to be performed",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "experiment_type",
          "description": "Type of experiment or assay to answer the question",
          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/Experiment",
      "@type": "ClassDefinition"
    },
    {
      "name": "Question",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/Question",
      "description": "A question to be answered about the gene",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "question__question",
        "question__experts"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "question",
          "description": "Question to be answered",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "experts",
          "description": "Experts to answer the question. These should be drawn from the authors of relevant publications already referenced. If no suitable experts are available, it's OK to leave this as an empty list!",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/Question",
      "@type": "ClassDefinition"
    },
    {
      "name": "RuleReview",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/RuleReview",
      "description": "A review of a UniProt annotation rule (ARBA or UniRule). Each review covers ONE rule and assesses its quality, literature support, and biological appropriateness.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "RuleReview_id",
        "description",
        "references",
        "ruleReview__status",
        "ruleReview__rule_type",
        "ruleReview__rule",
        "ruleReview__review_summary",
        "ruleReview__action",
        "ruleReview__action_rationale",
        "ruleReview__suggested_modifications",
        "ruleReview__parsimony",
        "ruleReview__literature_support",
        "ruleReview__condition_overlap",
        "ruleReview__go_specificity",
        "ruleReview__taxonomic_scope",
        "ruleReview__confidence",
        "ruleReview__supported_by"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "status",
          "description": "Status of the rule review",
          "range": "RuleReviewStatusEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "rule_type",
          "description": "Type of rule (ARBA or UniRule)",
          "range": "RuleTypeEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "rule",
          "description": "The embedded rule being reviewed",
          "range": "EmbeddedRule",
          "required": true,
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "review_summary",
          "description": "Overall summary of the review findings",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "action",
          "description": "Recommended action for this rule",
          "range": "RuleActionEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "action_rationale",
          "description": "Rationale for the recommended action",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "suggested_modifications",
          "description": "Specific modifications suggested if action is MODIFY",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "parsimony",
          "description": "Assessment of rule parsimony (simplicity vs complexity)",
          "range": "ParsimonyAssessment",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "literature_support",
          "description": "Assessment of literature support for the rule",
          "range": "LiteratureSupportAssessment",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "condition_overlap",
          "description": "Assessment of overlap between rule conditions",
          "range": "ConditionOverlapAssessment",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "go_specificity",
          "description": "Assessment of GO term specificity",
          "range": "GOSpecificityAssessment",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "taxonomic_scope",
          "description": "Assessment of taxonomic restriction appropriateness",
          "range": "TaxonomicScopeAssessment",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "confidence",
          "description": "Overall confidence in the rule (0.0 to 1.0)",
          "range": "float",
          "minimum_value": 0.0,
          "maximum_value": 1.0,
          "@type": "SlotDefinition"
        },
        {
          "name": "supported_by",
          "description": "Supporting text from literature for this review",
          "range": "SupportingTextInReference",
          "multivalued": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/RuleReview",
      "@type": "ClassDefinition"
    },
    {
      "name": "EmbeddedRule",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/EmbeddedRule",
      "description": "An embedded representation of an ARBA or UniRule for storage in YAML. Captures the essential structure: conditions (antecedent) and GO annotations (consequent).",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "embeddedRule__rule_id",
        "embeddedRule__condition_sets",
        "embeddedRule__go_annotations",
        "embeddedRule__ipr2go_redundancy",
        "embeddedRule__entries",
        "embeddedRule__reviewed_protein_count",
        "embeddedRule__unreviewed_protein_count",
        "embeddedRule__created_date",
        "embeddedRule__modified_date"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "rule_id",
          "description": "Original rule ID (e.g., ARBA00026249, UR000000070)",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "condition_sets",
          "description": "List of condition sets (OR-ed together). Each condition set is a conjunction (AND) of conditions. The rule fires if ANY condition set matches.",
          "range": "RuleConditionSet",
          "required": true,
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "go_annotations",
          "description": "GO terms assigned by this rule",
          "range": "RuleGOAnnotation",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "ipr2go_redundancy",
          "description": "Analysis of redundancy with InterPro2GO mappings",
          "range": "InterPro2GORedundancy",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "entries",
          "description": "Entry-centric view of all entities in the rule (domain conditions and GO terms). Each entry tracks its relationships (PREDICTS, PREDICTED_BY, EQUIV) to other entries.",
          "range": "RuleReviewEntry",
          "required": true,
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "reviewed_protein_count",
          "description": "Number of reviewed (Swiss-Prot) proteins annotated by this rule",
          "range": "integer",
          "@type": "SlotDefinition"
        },
        {
          "name": "unreviewed_protein_count",
          "description": "Number of unreviewed (TrEMBL) proteins annotated by this rule",
          "range": "integer",
          "@type": "SlotDefinition"
        },
        {
          "name": "created_date",
          "description": "Date the rule was created",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "modified_date",
          "description": "Date the rule was last modified",
          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/EmbeddedRule",
      "@type": "ClassDefinition"
    },
    {
      "name": "RuleConditionSet",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/RuleConditionSet",
      "description": "A set of conditions that must ALL be true (conjunction/AND). Multiple condition sets in a rule are OR-ed together (disjunction).",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "ruleConditionSet__number",
        "ruleConditionSet__conditions",
        "ruleConditionSet__notes",
        "ruleConditionSet__pairwise_overlap"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "number",
          "description": "1-based condition set number (CS1, CS2, CS3, etc.)",
          "range": "integer",
          "required": true,
          "minimum_value": 1,
          "@type": "SlotDefinition"
        },
        {
          "name": "conditions",
          "description": "Conditions in this set (all must match)",
          "range": "RuleCondition",
          "required": true,
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "notes",
          "description": "Reviewer notes on this specific condition set",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "pairwise_overlap",
          "description": "Pairwise overlap statistics for domain conditions in this set. Only computed for InterPro, FunFam, PANTHER conditions. Provides set difference metrics (uniqueness) and Jaccard similarity.",
          "range": "PairwiseOverlap",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/RuleConditionSet",
      "@type": "ClassDefinition"
    },
    {
      "name": "RuleCondition",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/RuleCondition",
      "description": "A single condition in a rule antecedent",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "ruleCondition__condition_type",
        "ruleCondition__value",
        "ruleCondition__curie",
        "ruleCondition__label",
        "ruleCondition__interpro_type",
        "ruleCondition__negated",
        "ruleCondition__protein_count",
        "ruleCondition__protein_database",
        "ruleCondition__uniqueness_score",
        "ruleCondition__sample_proteins"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "condition_type",
          "description": "Type of condition",
          "range": "ConditionTypeEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "value",
          "description": "The condition value (e.g., IPR000001, NCBITaxon:4751)",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "curie",
          "description": "Normalized CURIE form (e.g., InterPro:IPR000001, NCBITaxon:4751)",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "label",
          "description": "Human-readable label",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "interpro_type",
          "description": "InterPro entry type (family, domain, active_site, etc.). Only populated for InterPro conditions (condition_type = INTERPRO). Extracted from InterPro metadata or API.",
          "range": "InterProTypeEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "negated",
          "description": "Whether this is a negative condition (NOT)",
          "range": "boolean",
          "@type": "SlotDefinition"
        },
        {
          "name": "protein_count",
          "description": "Number of proteins matching this condition in specified database. Only populated for domain/family conditions (InterPro, FunFam, PANTHER). Null for taxon and other condition types.",
          "range": "integer",
          "minimum_value": 0,
          "@type": "SlotDefinition"
        },
        {
          "name": "protein_database",
          "description": "Which protein database was queried (e.g., SWISSPROT, TREMBL). Defaults to SWISSPROT (reviewed proteins only). Important to specify since counts differ dramatically between databases.",
          "range": "ProteinDatabaseEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "uniqueness_score",
          "description": "Measure of domain uniqueness (0.0 to 1.0). Calculated as 1.0 - mean(containment in other domains in same condition set). High score = more unique/specific domain. Low score = broad domain that commonly co-occurs.",
          "range": "float",
          "minimum_value": 0.0,
          "maximum_value": 1.0,
          "@type": "SlotDefinition"
        },
        {
          "name": "sample_proteins",
          "description": "Sample UniProt IDs matching this condition. Only included when protein_count < 20 to avoid bloating files. Limited to max 10 examples.",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/RuleCondition",
      "@type": "ClassDefinition"
    },
    {
      "name": "RuleGOAnnotation",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/RuleGOAnnotation",
      "description": "A GO annotation produced by the rule",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "ruleGOAnnotation__go_id",
        "ruleGOAnnotation__go_label",
        "ruleGOAnnotation__aspect"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "go_id",
          "description": "GO term ID (e.g., GO:0004791)",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "go_label",
          "description": "GO term name",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "aspect",
          "description": "GO aspect (F, P, or C)",
          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/RuleGOAnnotation",
      "@type": "ClassDefinition"
    },
    {
      "name": "PairwiseOverlap",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/PairwiseOverlap",
      "description": "Overlap statistics between two domain conditions (InterPro, FunFam, etc.) in the same condition set. Provides set difference metrics to measure uniqueness and redundancy.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "pairwiseOverlap__condition_a",
        "pairwiseOverlap__condition_b",
        "pairwiseOverlap__condition_a_label",
        "pairwiseOverlap__condition_b_label",
        "pairwiseOverlap__protein_database",
        "pairwiseOverlap__count_a",
        "pairwiseOverlap__count_b",
        "pairwiseOverlap__intersection_count",
        "pairwiseOverlap__a_minus_b_count",
        "pairwiseOverlap__b_minus_a_count",
        "pairwiseOverlap__jaccard_similarity",
        "pairwiseOverlap__containment_a_in_b",
        "pairwiseOverlap__containment_b_in_a",
        "pairwiseOverlap__interpretation",
        "pairwiseOverlap__condition_a_in_sets",
        "pairwiseOverlap__condition_b_in_sets"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "condition_a",
          "description": "First condition value (e.g., IPR005982)",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "condition_b",
          "description": "Second condition value (e.g., IPR008255)",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "condition_a_label",
          "description": "Human-readable label for condition A",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "condition_b_label",
          "description": "Human-readable label for condition B",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "protein_database",
          "description": "Which protein database was queried (SWISSPROT or TREMBL)",
          "range": "ProteinDatabaseEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "count_a",
          "description": "Number of proteins matching condition A in specified database",
          "range": "integer",
          "required": true,
          "minimum_value": 0,
          "@type": "SlotDefinition"
        },
        {
          "name": "count_b",
          "description": "Number of proteins matching condition B in specified database",
          "range": "integer",
          "required": true,
          "minimum_value": 0,
          "@type": "SlotDefinition"
        },
        {
          "name": "intersection_count",
          "description": "Number of proteins matching BOTH A AND B (|A \u2229 B|) in specified database",
          "range": "integer",
          "required": true,
          "minimum_value": 0,
          "@type": "SlotDefinition"
        },
        {
          "name": "a_minus_b_count",
          "description": "Number of proteins in A but not in B (|A - B|). Represents the uniqueness of A with respect to B. High value = A adds unique coverage beyond B. Zero value = A is completely contained in B (A \u2286 B).",
          "range": "integer",
          "required": true,
          "minimum_value": 0,
          "@type": "SlotDefinition"
        },
        {
          "name": "b_minus_a_count",
          "description": "Number of proteins in B but not in A (|B - A|). Represents the uniqueness of B with respect to A. High value = B adds unique coverage beyond A. Zero value = B is completely contained in A (B \u2286 A).",
          "range": "integer",
          "required": true,
          "minimum_value": 0,
          "@type": "SlotDefinition"
        },
        {
          "name": "jaccard_similarity",
          "description": "Jaccard similarity coefficient: |A \u2229 B| / |A \u222a B| = intersection / (count_a + count_b - intersection). 0.0 = no overlap, 1.0 = complete overlap.",
          "range": "float",
          "required": true,
          "minimum_value": 0.0,
          "maximum_value": 1.0,
          "@type": "SlotDefinition"
        },
        {
          "name": "containment_a_in_b",
          "description": "Proportion of A contained in B: |A \u2229 B| / |A|. 1.0 means A is completely contained in B (A \u2286 B).",
          "range": "float",
          "required": true,
          "minimum_value": 0.0,
          "maximum_value": 1.0,
          "@type": "SlotDefinition"
        },
        {
          "name": "containment_b_in_a",
          "description": "Proportion of B contained in A: |A \u2229 B| / |B|. 1.0 means B is completely contained in A (B \u2286 A).",
          "range": "float",
          "required": true,
          "minimum_value": 0.0,
          "maximum_value": 1.0,
          "@type": "SlotDefinition"
        },
        {
          "name": "interpretation",
          "description": "Automated interpretation of overlap pattern",
          "range": "OverlapInterpretationEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "condition_a_in_sets",
          "description": "List of 1-based condition set indices where condition A appears",
          "range": "integer",
          "multivalued": true,
          "minimum_value": 1,
          "@type": "SlotDefinition"
        },
        {
          "name": "condition_b_in_sets",
          "description": "List of 1-based condition set indices where condition B appears",
          "range": "integer",
          "multivalued": true,
          "minimum_value": 1,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/PairwiseOverlap",
      "@type": "ClassDefinition"
    },
    {
      "name": "RuleReviewEntry",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/RuleReviewEntry",
      "description": "An entity in the rule - either a domain/family condition or a GO term target. Each entry tracks its relationships (predictions, predicted-by, equivalence) to other entries.",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "ruleReviewEntry__id",
        "ruleReviewEntry__label",
        "ruleReviewEntry__type",
        "ruleReviewEntry__appears_in_condition_sets",
        "ruleReviewEntry__protein_count",
        "ruleReviewEntry__source",
        "ruleReviewEntry__asserted_predicted_go_terms",
        "ruleReviewEntry__related_entries"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "id",
          "description": "Identifier (IPR005982, GO:0004791, 3.50.50.60:FF:000064, etc.)",
          "identifier": true,
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "label",
          "description": "Human-readable name",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "type",
          "description": "Type of entry (INTERPRO, FUNFAM, PANTHER, GO_TERM, etc.)",
          "range": "EntryTypeEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "appears_in_condition_sets",
          "description": "Which condition sets (1-based) contain this entry (for domain conditions only)",
          "range": "integer",
          "multivalued": true,
          "minimum_value": 1,
          "@type": "SlotDefinition"
        },
        {
          "name": "protein_count",
          "description": "Number of proteins matching this condition (from SwissProt)",
          "range": "integer",
          "@type": "SlotDefinition"
        },
        {
          "name": "source",
          "description": "Source of this entry if external to the rule (e.g., 'ipr2go' for InterPro entries that map to the same GO term via InterPro2GO but are not part of any condition set)",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "asserted_predicted_go_terms",
          "description": "GO terms that this entry maps to via external mappings (e.g., ipr2go). Only populated for external entries not in the rule's condition sets.",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "related_entries",
          "description": "Relationships to other entries in the rule",
          "range": "RelatedEntry",
          "multivalued": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/RuleReviewEntry",
      "@type": "ClassDefinition"
    },
    {
      "name": "RelatedEntry",
      "definition_uri": "https://w3id.org/ai4curation/gene_review/RelatedEntry",
      "description": "A relationship from this entry to another entry in the rule. Categorized as PREDICTS (this \u2192 other), PREDICTED_BY (other \u2192 this), or EQUIV (bidirectional).",
      "from_schema": "https://ai4curation.io/ai-gene-review",
      "slots": [
        "relatedEntry__relationship",
        "relatedEntry__target_id",
        "relatedEntry__containment",
        "relatedEntry__jaccard_similarity",
        "relatedEntry__intersection_count",
        "relatedEntry__exclusive_count"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "relationship",
          "description": "Type of relationship",
          "range": "EntryRelationshipEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "target_id",
          "description": "ID of the related entry",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "containment",
          "description": "Containment score (0-1) for the directional relationship. For PREDICTS: this_in_target (how much of this is contained in target). For PREDICTED_BY: target_in_this (how much of target is contained in this). For EQUIV: max of both directions.",
          "range": "float",
          "minimum_value": 0.0,
          "maximum_value": 1.0,
          "@type": "SlotDefinition"
        },
        {
          "name": "jaccard_similarity",
          "description": "Jaccard similarity coefficient (0-1)",
          "range": "float",
          "minimum_value": 0.0,
          "maximum_value": 1.0,
          "@type": "SlotDefinition"
        },
        {
          "name": "intersection_count",
          "description": "Number of proteins in both this and target",
          "range": "integer",
          "@type": "SlotDefinition"
        },
        {
          "name": "exclusive_count",
          "description": "Number of proteins exclusive to the \"source\" of the relationship. For PREDICTS: proteins in this but not target. For PREDICTED_BY: proteins in target but not this. For EQUIV: proteins in this but not target (A - B).",
          "range": "integer",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/ai4curation/gene_review/RelatedEntry",
