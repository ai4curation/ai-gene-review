@prefix ECO: <http://purl.obolibrary.org/obo/ECO_> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .
@prefix SO: <http://purl.obolibrary.org/obo/SO_> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix gene_review: <https://w3id.org/ai4curation/gene_review/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

gene_review:ChemicalEntityDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a chemical entity, metabolite, cofactor, ion, or small molecule." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ] ;
    sh:targetClass gene_review:ChemicalEntityDescriptor .

gene_review:GeneReview a sh:NodeShape ;
    sh:closed true ;
    sh:description "Complete review for a gene" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:AlternativeProduct ;
            sh:description "Alternative splicing products (isoforms) of the gene. Seeded from UniProt ALTERNATIVE PRODUCTS section. Only populated if there are multiple isoforms. Use this to document isoform-specific functions and biology. DEPRECATED: Use functional_isoforms instead for curated functional classes." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path gene_review:alternative_products ],
        [ sh:class gene_review:FunctionalIsoform ;
            sh:description "Curated functional isoform classes for the gene. Unlike alternative_products (which is seeded from UniProt), this field is purely curator/agent-defined to capture FUNCTIONALLY RELEVANT distinctions. Examples: - Splice classes that group multiple UniProt isoforms (e.g., WT1 +KTS vs -KTS) - Cleavage products from polyproteins (e.g., POMC peptides) - Modification states with distinct functions Only populate when there ARE functionally distinct forms worth documenting." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path gene_review:functional_isoforms ],
        [ sh:class gene_review:Reference ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path gene_review:references ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ],
        [ sh:description "Type of gene product (protein, ncRNA, etc.)" ;
            sh:in ( SO:0001217 SO:0000276 SO:0001877 SO:0000275 SO:0000274 SO:0000253 SO:0000252 SO:0001035 SO:0000644 SO:0000336 SO:0000655 ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path gene_review:product_type ],
        [ sh:class gene_review:KnowledgeGap ;
            sh:description "Curated, literature-grounded statements of what is NOT known — applicable at the level of the whole gene, a single existing annotation, a core function, a whole module, or a single module step/node. The inverse of core_functions: everywhere else the schema records what IS known; here it records, with the same evidentiary discipline, what is not. See the Function Knowledge Gaps project (projects/FUNCTION_KNOWLEDGE_GAPS.md)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path gene_review:knowledge_gaps ],
        [ sh:datatype xsd:string ;
            sh:description "Tags associated with the gene for categorization and organization" ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:tags ],
        [ sh:class gene_review:ProposedOntologyTerm ;
            sh:description "Proposed new ontology terms that should exist but don't" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path gene_review:proposed_new_terms ],
        [ sh:class gene_review:CoreFunction ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path gene_review:core_functions ],
        [ sh:datatype xsd:string ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:aliases ],
        [ sh:class gene_review:ExistingAnnotation ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path gene_review:existing_annotations ],
        [ sh:class gene_review:Experiment ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path gene_review:suggested_experiments ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path gene_review:taxon ],
        [ sh:class gene_review:Question ;
            sh:description "Suggested questions to ask experts about the gene. Only include if not obvious from the literature." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path gene_review:suggested_questions ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:description ],
        [ sh:description "Overall status of the gene review" ;
            sh:in ( "INITIALIZED" "IN_PROGRESS" "DRAFT" "COMPLETE" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path gene_review:status ],
        [ sh:datatype xsd:string ;
            sh:description "Symbol of the gene" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:gene_symbol ] ;
    sh:targetClass gene_review:GeneReview .

gene_review:ModuleReview a sh:NodeShape ;
    sh:closed true ;
    sh:description "Review or curation record for a recursively decomposable biological module. This can describe a pathway, organelle lifecycle, protein complex, molecular function, developmental process, or abstract/evolutionary functional plan." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:KnowledgeGap ;
            sh:description "Curated, literature-grounded statements of what is NOT known — applicable at the level of the whole gene, a single existing annotation, a core function, a whole module, or a single module step/node. The inverse of core_functions: everywhere else the schema records what IS known; here it records, with the same evidentiary discipline, what is not. See the Function Knowledge Gaps project (projects/FUNCTION_KNOWLEDGE_GAPS.md)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:knowledge_gaps ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:status ],
        [ sh:class gene_review:Reference ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gene_review:references ],
        [ sh:datatype xsd:string ;
            sh:description "Title of the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:class gene_review:ModuleNode ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path gene_review:module ] ;
    sh:targetClass gene_review:ModuleReview .

gene_review:PredictionReview a sh:NodeShape ;
    sh:closed true ;
    sh:description "Review of computational/ML predictions for a gene that are NOT in the curated GOA/UniProt annotations. This captures predictions from methods like DeepECTF, PANTHER/IBA, InterPro2GO, CLEAN, GloEC, MAPred, etc. and evaluates them against literature and bioinformatic evidence. Inspired by the systematic evaluation in de Crécy-Lagard et al. 2025 (PMID:40703034)." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:taxon ],
        [ sh:datatype xsd:string ;
            sh:description "Symbol of the gene" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:gene_symbol ],
        [ sh:class gene_review:Reference ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gene_review:references ],
        [ sh:datatype xsd:string ;
            sh:description "Locus tag for the gene (e.g., b1267 for E. coli)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:locus_tag ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt accession for the gene product" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ],
        [ sh:class gene_review:PredictedAnnotation ;
            sh:description "List of predictions to review" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path gene_review:predictions ],
        [ sh:description "Overall status of the gene review" ;
            sh:in ( "INITIALIZED" "IN_PROGRESS" "DRAFT" "COMPLETE" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path gene_review:status ],
        [ sh:datatype xsd:string ;
            sh:description "Summary of the prediction review findings" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description "Paths to supporting source documents (e.g., reasoning traces, raw model outputs) for provenance" ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gene_review:source_documents ] ;
    sh:targetClass gene_review:PredictionReview .

gene_review:RuleReview a sh:NodeShape ;
    sh:closed true ;
    sh:description "A review of a UniProt annotation rule (ARBA or UniRule). Each review covers ONE rule and assesses its quality, literature support, and biological appropriateness." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The rule ID (e.g., ARBA00026249, UR000000070)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ],
        [ sh:class gene_review:ConditionOverlapAssessment ;
            sh:description "Assessment of overlap between rule conditions" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path gene_review:condition_overlap ],
        [ sh:datatype xsd:string ;
            sh:description "Specific modifications suggested if action is MODIFY" ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path gene_review:suggested_modifications ],
        [ sh:class gene_review:TaxonomicScopeAssessment ;
            sh:description "Assessment of taxonomic restriction appropriateness" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path gene_review:taxonomic_scope ],
        [ sh:datatype xsd:string ;
            sh:description "Rationale for the recommended action" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gene_review:action_rationale ],
        [ sh:class gene_review:SupportingTextInReference ;
            sh:description "Supporting text from literature for this review" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path gene_review:supported_by ],
        [ sh:description "Status of the rule review" ;
            sh:in ( "PENDING" "IN_PROGRESS" "COMPLETE" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path gene_review:status ],
        [ sh:datatype xsd:float ;
            sh:description "Overall confidence in the rule (0.0 to 1.0)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path gene_review:confidence ],
        [ sh:class gene_review:GOSpecificityAssessment ;
            sh:description "Assessment of GO term specificity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path gene_review:go_specificity ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:description ],
        [ sh:description "Recommended action for this rule" ;
            sh:in ( "ACCEPT" "MODIFY" "DEPRECATE" "SPLIT" "MERGE" "UNDECIDED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path gene_review:action ],
        [ sh:class gene_review:EmbeddedRule ;
            sh:description "The embedded rule being reviewed" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:rule ],
        [ sh:datatype xsd:string ;
            sh:description "Overall summary of the review findings" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:review_summary ],
        [ sh:class gene_review:Reference ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:references ],
        [ sh:description "Type of rule (ARBA or UniRule)" ;
            sh:in ( "ARBA" "UNIRULE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path gene_review:rule_type ],
        [ sh:class gene_review:ParsimonyAssessment ;
            sh:description "Assessment of rule parsimony (simplicity vs complexity)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path gene_review:parsimony ],
        [ sh:class gene_review:LiteratureSupportAssessment ;
            sh:description "Assessment of literature support for the rule" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path gene_review:literature_support ] ;
    sh:targetClass gene_review:RuleReview .

gene_review:AlternativeProduct a sh:NodeShape ;
    sh:closed true ;
    sh:description "An alternative splicing product (isoform) of the gene. Corresponds to UniProt isoform entries. Use this to document isoform-specific functions where different isoforms have distinct or even antagonistic biological activities. DEPRECATED: Use FunctionalIsoform instead for curated functional classes." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Agent-populated description of the isoform's function. Document any isoform-specific functions, expression patterns, or biological activities that differ from other isoforms." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description "Common name of the isoform (e.g., Bcl-xL, Bcl-xS)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:name ],
        [ sh:datatype xsd:string ;
            sh:description "Brief note about sequence differences (e.g., \"lacks exon 2\", \"shorter C-terminus\")" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:sequence_note ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt isoform ID (e.g., Q07817-1, Q07817-2)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ] ;
    sh:targetClass gene_review:AlternativeProduct .

gene_review:AnatomicalEntityDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for an anatomical entity, tissue, organismal region, or structure." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ] ;
    sh:targetClass gene_review:AnatomicalEntityDescriptor .

gene_review:AnnotationExtension a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Predicate of the extension" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdf:predicate ],
        [ sh:class gene_review:Term ;
            sh:description "Term to be annotated" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gene_review:term ] ;
    sh:targetClass gene_review:AnnotationExtension .

gene_review:BiologicalProcessDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a biological process, pathway, reaction, or process-like module grounding." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path gene_review:notes ],
        [ sh:class gene_review:Descriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:starts_with ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:Descriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:ends_with ],
        [ sh:class gene_review:Descriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:occurs_in ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:preferred_term ],
        [ sh:class gene_review:Descriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path gene_review:outputs ],
        [ sh:class gene_review:Descriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path gene_review:inputs ] ;
    sh:targetClass gene_review:BiologicalProcessDescriptor .

gene_review:CellTypeDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a cell type or cell state." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ] ;
    sh:targetClass gene_review:CellTypeDescriptor .

gene_review:ComplexUnit a sh:NodeShape ;
    sh:closed true ;
    sh:description "A role-bearing unit within a protein complex descriptor." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:label ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:role ],
        [ sh:class gene_review:MolecularFunctionDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:function ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:description "Optional stoichiometry or copy-number statement when known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:stoichiometry ],
        [ sh:class gene_review:ParticipantSelector ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:participant ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gene_review:notes ] ;
    sh:targetClass gene_review:ComplexUnit .

gene_review:ConditionOverlapAssessment a sh:NodeShape ;
    sh:closed true ;
    sh:description "Assessment of overlap between rule conditions" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Notes on condition overlap - e.g., \"IPR000001 and IPR000002 both represent the same structural domain\" or \"FunFam subsumes the InterPro entry\"" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:notes ],
        [ sh:description "Overlap assessment value" ;
            sh:in ( "NONE" "MINOR" "SIGNIFICANT" "COMPLETE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:assessment ],
        [ sh:class gene_review:SupportingTextInReference ;
            sh:description "Supporting text from literature for this assessment" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:supported_by ] ;
    sh:targetClass gene_review:ConditionOverlapAssessment .

gene_review:CoreFunction a sh:NodeShape ;
    sh:closed true ;
    sh:description "A core function is a GO-CAM-like annotation of the core evolved functions of a gene. This is a synthesis of the reviewed core annotations, brought together into a unified GO-CAM-like representation." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Description of the core function" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:Term ;
            sh:description "The protein-containing complex (GO:0032991 descendant) that this gene product is an active unit of. Use this — not locations — for complex membership (e.g. ribosome, spliceosome, EMC, signal peptidase complex)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path gene_review:in_complex ],
        [ sh:class gene_review:Term ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path gene_review:substrates ],
        [ sh:class gene_review:SupportingTextInReference ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:supported_by ],
        [ sh:class gene_review:Term ;
            sh:description "Cellular anatomical entities (e.g. membranes, nucleus, cytosol, organelle parts) where the gene product functions. Do NOT use this for protein-containing complexes (GO:0032991 and its descendants) — record complex membership in in_complex instead." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path gene_review:locations ],
        [ sh:class gene_review:Term ;
            sh:description "The molecular function this gene product enables (i.e., has the activity independently). For complex subunits that contribute to but don't independently have a complex-level activity, use contributes_to_molecular_function instead and put a subunit-specific MF here (e.g., structural constituent of ribosome, electron transfer activity)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gene_review:molecular_function ],
        [ sh:class gene_review:Term ;
            sh:description "A molecular function that this gene product contributes to as part of a complex, but does not independently enable. Used for accessory/structural subunits of multi-protein complexes (e.g., an accessory subunit of Complex I contributes_to NADH dehydrogenase activity but does not have that activity on its own). The molecular_function slot should then contain the subunit-specific activity (e.g., structural molecule activity)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gene_review:contributes_to_molecular_function ],
        [ sh:class gene_review:Term ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path gene_review:anatomical_locations ],
        [ sh:class gene_review:Term ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path gene_review:directly_involved_in ],
        [ sh:class gene_review:KnowledgeGap ;
            sh:description "Curated, literature-grounded statements of what is NOT known — applicable at the level of the whole gene, a single existing annotation, a core function, a whole module, or a single module step/node. The inverse of core_functions: everywhere else the schema records what IS known; here it records, with the same evidentiary discipline, what is not. See the Function Knowledge Gaps project (projects/FUNCTION_KNOWLEDGE_GAPS.md)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path gene_review:knowledge_gaps ] ;
    sh:targetClass gene_review:CoreFunction .

gene_review:DevelopmentalStageDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a developmental stage, life-cycle stage, or temporal window." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ] ;
    sh:targetClass gene_review:DevelopmentalStageDescriptor .

gene_review:EmbeddedRule a sh:NodeShape ;
    sh:closed true ;
    sh:description "An embedded representation of an ARBA or UniRule for storage in YAML. Captures the essential structure: conditions (antecedent) and GO annotations (consequent)." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Number of reviewed (Swiss-Prot) proteins annotated by this rule" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:reviewed_protein_count ],
        [ sh:class gene_review:RuleConditionSet ;
            sh:description "List of condition sets (OR-ed together). Each condition set is a conjunction (AND) of conditions. The rule fires if ANY condition set matches." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path gene_review:condition_sets ],
        [ sh:datatype xsd:string ;
            sh:description "Date the rule was created" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gene_review:created_date ],
        [ sh:datatype xsd:string ;
            sh:description "Original rule ID (e.g., ARBA00026249, UR000000070)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:rule_id ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of unreviewed (TrEMBL) proteins annotated by this rule" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:unreviewed_protein_count ],
        [ sh:datatype xsd:string ;
            sh:description "Date the rule was last modified" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gene_review:modified_date ],
        [ sh:class gene_review:RuleGOAnnotation ;
            sh:description "GO terms assigned by this rule" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:go_annotations ],
        [ sh:class gene_review:RuleReviewEntry ;
            sh:description "Entry-centric view of all entities in the rule (domain conditions and GO terms). Each entry tracks its relationships (PREDICTS, PREDICTED_BY, EQUIV) to other entries." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gene_review:entries ],
        [ sh:class gene_review:InterPro2GORedundancy ;
            sh:description "Analysis of redundancy with InterPro2GO mappings" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:ipr2go_redundancy ] ;
    sh:targetClass gene_review:EmbeddedRule .

gene_review:ExistingAnnotation a sh:NodeShape ;
    sh:closed true ;
    sh:description "An existing annotation from the GO database, plus a review of the annotation." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether the term is negated" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:negated ],
        [ sh:class gene_review:Reference ;
            sh:description "ID of the original reference" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path gene_review:original_reference_id ],
        [ sh:class gene_review:Review ;
            sh:description "Review of the gene" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path gene_review:review ],
        [ sh:class gene_review:Term ;
            sh:description "Term to be annotated" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt isoform identifier (e.g., \"P19544-1\" for WT1 isoform 1). Only populated when the annotation is specific to a particular isoform rather than the canonical protein sequence. Note that just because an experiment used a particular isoform doesn't mean the annotation is isoform-specific - it may apply to all isoforms. Use this field only when there is clear evidence the annotation is isoform-specific." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gene_review:isoform ],
        [ sh:datatype xsd:string ;
            sh:description "IDs of the supporting entities" ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gene_review:supporting_entities ],
        [ sh:description "Evidence code (e.g., IDA, IBA, ISS, TAS)" ;
            sh:in ( ECO:0000269 ECO:0000314 ECO:0000353 ECO:0000315 ECO:0000316 ECO:0000270 ECO:0006056 ECO:0007005 ECO:0007001 ECO:0007003 ECO:0007007 ECO:0000318 ECO:0000319 ECO:0000320 ECO:0000321 ECO:0000250 ECO:0000266 ECO:0000247 ECO:0000255 ECO:0000317 ECO:0000245 ECO:0000304 ECO:0000303 ECO:0000305 ECO:0000307 ECO:0000501 ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path gene_review:evidence_type ],
        [ sh:description "The GO annotation qualifier specifying the relationship between the gene product and the term. For MF annotations, distinguishes 'enables' (gene product has the activity independently) from 'contributes_to' (gene product contributes to a complex's activity but does not have the activity alone). For BP, distinguishes 'involved_in', 'acts_upstream_of', etc. For CC, distinguishes 'located_in', 'part_of', 'is_active_in', 'colocalizes_with'." ;
            sh:in ( "enables" "contributes_to" "involved_in" "acts_upstream_of" "acts_upstream_of_positive_effect" "acts_upstream_of_negative_effect" "acts_upstream_of_or_within" "acts_upstream_of_or_within_positive_effect" "acts_upstream_of_or_within_negative_effect" "located_in" "is_active_in" "part_of" "colocalizes_with" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path gene_review:qualifier ],
        [ sh:class gene_review:AnnotationExtension ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:extensions ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the annotation is retired or replaced" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:retired ] ;
    sh:targetClass gene_review:ExistingAnnotation .

gene_review:Experiment a sh:NodeShape ;
    sh:closed true ;
    sh:description "A suggested experiment to answer a question about the gene" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Type of experiment or assay to answer the question" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:experiment_type ],
        [ sh:datatype xsd:string ;
            sh:description "Hypothesis to be investigated" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:hypothesis ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the experiment to be performed" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ] ;
    sh:targetClass gene_review:Experiment .

gene_review:FamilyDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a protein family, orthogroup, or other evolutionary grouping." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:GeneProductDescriptor ;
            sh:description "Representative concrete members used to orient the family. These are examples, not an exhaustive member list and not a claim that the module is limited to these proteins." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path gene_review:representative_members ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:preferred_term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:notes ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gene_review:term ] ;
    sh:targetClass gene_review:FamilyDescriptor .

gene_review:Finding a sh:NodeShape ;
    sh:closed true ;
    sh:description "A finding is a statement about a gene, which is supported by a reference. Similar to \"comments\" in uniprot" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Concise statement describing an aspect of the gene" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:statement ],
        [ sh:description "Type of section in the reference (e.g., 'ABSTRACT', 'METHODS', 'RESULTS', 'DISCUSSION')" ;
            sh:in ( IAO:0000305 IAO:0000315 IAO:0000630 IAO:0000316 IAO:0000639 IAO:0000317 IAO:0000318 IAO:0000319 IAO:0000615 IAO:0000326 IAO:0000326 "DATABASE_ENTRY" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path gene_review:reference_section_type ],
        [ sh:class gene_review:FindingReview ;
            sh:description "Manual reviewer assessment of this specific finding - in particular whether the finding remains current, is disputed, or has been overturned/superseded by later evidence. Reviewer-supplied; distinct from the statement/supporting_text that describe the finding itself." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:finding_review ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the full text is unavailable" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:full_text_unavailable ],
        [ sh:datatype xsd:string ;
            sh:description "Supporting text from the publication. This should be exact substrings. Different substrings can be broken up by '...'s. These substrings will be checked against the actual text of the paper. If editorialization is necessary, put this in square brackets (this is not checked). For example, you can say '...[CFAP300 shows] transport within cilia is IFT dependent...'" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:supporting_text ] ;
    sh:targetClass gene_review:Finding .

gene_review:FindingReview a sh:NodeShape ;
    sh:closed true ;
    sh:description "Manual reviewer assessment of a specific finding within a reference - in particular whether it remains current, is disputed, or has been overturned/superseded by later evidence. This is finer-grained than reference_review (which assesses the whole reference); a paper may contain some findings that stand and others that are overturned. All fields optional and reviewer-supplied." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Reviewer's assessment of the empirical standing of a specific finding in light of other evidence (e.g. whether it has been disputed or overturned)." ;
            sh:in ( "CURRENT" "CORROBORATED" "DISPUTED" "OVERTURNED" "UNVERIFIED" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path gene_review:finding_status ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note explaining the relevance/correctness judgment (e.g. what was verified, or why a citation is wrong, disputed, or low quality)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:review_notes ],
        [ sh:class gene_review:Reference ;
            sh:description "Reference(s) that dispute, correct, or overturn this finding. Used together with finding_status DISPUTED or OVERTURNED." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gene_review:superseded_by ] ;
    sh:targetClass gene_review:FindingReview .

gene_review:FunctionalIsoform a sh:NodeShape ;
    sh:closed true ;
    sh:description "A curated functional isoform class. Unlike AlternativeProduct (which maps 1:1 to UniProt isoforms), this captures FUNCTIONALLY RELEVANT distinctions that may: - Group multiple UniProt isoforms into a functional class (e.g., WT1 +KTS isoforms) - Represent cleavage products from polyproteins (e.g., POMC peptides) - Describe modification states or conformational variants Only create entries when there ARE functionally distinct forms worth documenting." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Type of functional distinction (SPLICE_VARIANT, SPLICE_CLASS, CLEAVAGE_PRODUCT, MODIFICATION_STATE, CONFORMATIONAL_STATE)." ;
            sh:in ( "SPLICE_VARIANT" "SPLICE_CLASS" "CLEAVAGE_PRODUCT" "MODIFICATION_STATE" "CONFORMATIONAL_STATE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path gene_review:type ],
        [ sh:class gene_review:Term ;
            sh:description "GO terms that are specific to this functional class. These are terms that should NOT be annotated to the gene as a whole, only to this specific form. Using Term objects enables linkml-term-validator checking." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path gene_review:isoform_specific_terms ],
        [ sh:datatype xsd:string ;
            sh:description "Curator-defined identifier for this functional class. Use a descriptive format like GENE_CLASS (e.g., WT1_PLUS_KTS, POMC_ACTH, BCL2L1_XL)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ],
        [ sh:class gene_review:FunctionalIsoformMapping ;
            sh:description "Mappings to underlying UniProt identifiers. Optional - some functional classes may not map cleanly to specific UniProt IDs." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:maps_to ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name for this functional class (e.g., \"+KTS isoforms\", \"ACTH/Corticotropin\", \"Bcl-xL\")." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:name ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of this functional class. Document the specific functions, how they differ from other classes, tissue specificity, and any antagonistic relationships (e.g., \"OREXIGENIC - opposite to alpha-MSH\")." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:description ] ;
    sh:targetClass gene_review:FunctionalIsoform .

gene_review:FunctionalIsoformMapping a sh:NodeShape ;
    sh:closed true ;
    sh:description "A mapping from a functional isoform class to underlying UniProt identifiers. Allows grouping multiple UniProt isoforms or chains into a single functional class." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Type of identifier (UNIPROT_ISOFORM or UNIPROT_CHAIN)" ;
            sh:in ( "UNIPROT_ISOFORM" "UNIPROT_CHAIN" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:type ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt identifiers belonging to this functional class. For UNIPROT_ISOFORM: P19544-1, P19544-2, etc. For UNIPROT_CHAIN: PRO_0000024969, PRO_0000024970, etc." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:ids ],
        [ sh:datatype xsd:string ;
            sh:description "Residue range for cleavage products (e.g., \"138-176\" for ACTH). Only applicable for UNIPROT_CHAIN type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:residues ] ;
    sh:targetClass gene_review:FunctionalIsoformMapping .

gene_review:GOSpecificityAssessment a sh:NodeShape ;
    sh:closed true ;
    sh:description "Assessment of GO term specificity" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:SupportingTextInReference ;
            sh:description "Supporting text from literature for this assessment" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:supported_by ],
        [ sh:datatype xsd:string ;
            sh:description "Notes on specificity - suggested alternative terms if too broad/narrow" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:notes ],
        [ sh:description "Specificity assessment value" ;
            sh:in ( "TOO_BROAD" "APPROPRIATE" "TOO_NARROW" "MISMATCHED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:assessment ] ;
    sh:targetClass gene_review:GOSpecificityAssessment .

gene_review:InterPro2GORedundancy a sh:NodeShape ;
    sh:closed true ;
    sh:description "Analysis of whether rule GO annotations are redundant with existing InterPro2GO mappings from the GO Consortium." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:RedundantAnnotation ;
            sh:description "GO annotations that already exist in InterPro2GO" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path gene_review:redundant_annotations ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable summary of redundancy analysis" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:summary ],
        [ sh:datatype xsd:string ;
            sh:description "GO IDs not found in InterPro2GO for any rule condition" ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:novel_annotations ] ;
    sh:targetClass gene_review:InterPro2GORedundancy .

gene_review:LiteratureSupportAssessment a sh:NodeShape ;
    sh:closed true ;
    sh:description "Assessment of literature support for the rule" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:SupportingTextInReference ;
            sh:description "Supporting text from literature for this assessment" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:supported_by ],
        [ sh:description "Level of literature support" ;
            sh:in ( "STRONG" "MODERATE" "WEAK" "NONE" "CONTRADICTED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:assessment ],
        [ sh:datatype xsd:string ;
            sh:description "Notes on literature support - key papers, gaps in evidence" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:notes ] ;
    sh:targetClass gene_review:LiteratureSupportAssessment .

gene_review:ModuleAnnoton a sh:NodeShape ;
    sh:closed true ;
    sh:description "A leaf role assertion in a module. The participant may be a concrete gene or an abstract selector, and the function/process/location fields are descriptor holders rather than direct GO annotation exports." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:role_description ],
        [ sh:class gene_review:MolecularFunctionDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:function ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:label ],
        [ sh:class gene_review:CellularComponentDescriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:locations ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:BiologicalProcessDescriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:processes ],
        [ sh:class gene_review:ParticipantSelector ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:participant ] ;
    sh:targetClass gene_review:ModuleAnnoton .

gene_review:ModuleConnection a sh:NodeShape ;
    sh:closed true ;
    sh:description "A connection between module nodes, annotons, or other named elements. Source and target are IDs scoped to the module document." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:ModuleContext ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:context ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:target ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gene_review:notes ],
        [ sh:in ( "PRECEDES" "CAUSES" "POSITIVELY_REGULATES" "NEGATIVELY_REGULATES" "PROVIDES_INPUT_FOR" "HAS_INPUT" "HAS_OUTPUT" "PART_OF" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path gene_review:connection_type ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:RelationDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:predicate ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:source ] ;
    sh:targetClass gene_review:ModuleConnection .

gene_review:ModulePart a sh:NodeShape ;
    sh:closed true ;
    sh:description "A conjunctive part or step of a module node." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:ModuleNode ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gene_review:node ],
        [ sh:datatype xsd:string ;
            sh:description "Curator-supplied role of this part within the parent module." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:role ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:integer ;
            sh:description "Optional display or temporal order. Equal or absent values imply partial ordering only." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:order ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether this part is optional in the parent module." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:optional ] ;
    sh:targetClass gene_review:ModulePart .

gene_review:ModuleVariantSet a sh:NodeShape ;
    sh:closed true ;
    sh:description "A set of alternative implementations for a module node or part. Variants may themselves contain parts, annotons, connections, and nested variant sets." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:ModuleNode ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gene_review:variants ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:label ],
        [ sh:datatype xsd:string ;
            sh:description "The dimension along which these variants differ, e.g. taxon, cell type, compartment, route, enzyme family." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:axis ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:notes ],
        [ sh:description "How many variants may be selected in a concrete realization." ;
            sh:in ( "EXACTLY_ONE" "ONE_OR_MORE" "ZERO_OR_MORE" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path gene_review:selection ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ] ;
    sh:targetClass gene_review:ModuleVariantSet .

gene_review:PairwiseOverlap a sh:NodeShape ;
    sh:closed true ;
    sh:description "Overlap statistics between two domain conditions (InterPro, FunFam, etc.) in the same condition set. Provides set difference metrics to measure uniqueness and redundancy." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable label for condition B" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:condition_b_label ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of proteins matching BOTH A AND B (|A ∩ B|) in specified database" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gene_review:intersection_count ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of proteins in B but not in A (|B - A|). Represents the uniqueness of B with respect to A. High value = B adds unique coverage beyond A. Zero value = B is completely contained in A (B ⊆ A)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path gene_review:b_minus_a_count ],
        [ sh:datatype xsd:string ;
            sh:description "Second condition value (e.g., IPR008255)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:condition_b ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label for condition A" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:condition_a_label ],
        [ sh:datatype xsd:float ;
            sh:description "Proportion of A contained in B: |A ∩ B| / |A|. 1.0 means A is completely contained in B (A ⊆ B)." ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minCount 1 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path gene_review:containment_a_in_b ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of proteins in A but not in B (|A - B|). Represents the uniqueness of A with respect to B. High value = A adds unique coverage beyond B. Zero value = A is completely contained in B (A ⊆ B)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gene_review:a_minus_b_count ],
        [ sh:datatype xsd:float ;
            sh:description "Jaccard similarity coefficient: |A ∩ B| / |A ∪ B| = intersection / (count_a + count_b - intersection). 0.0 = no overlap, 1.0 = complete overlap." ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minCount 1 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path gene_review:jaccard_similarity ],
        [ sh:datatype xsd:integer ;
            sh:description "List of 1-based condition set indices where condition B appears" ;
            sh:minInclusive 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path gene_review:condition_b_in_sets ],
        [ sh:description "Automated interpretation of overlap pattern" ;
            sh:in ( "REDUNDANT" "SUBSET" "HIGH_OVERLAP" "MODERATE" "LOW" "DISJOINT" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path gene_review:interpretation ],
        [ sh:description "Which protein database was queried (SWISSPROT or TREMBL)" ;
            sh:in ( "SWISSPROT" "TREMBL" "UNIPROT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path gene_review:protein_database ],
        [ sh:datatype xsd:string ;
            sh:description "First condition value (e.g., IPR005982)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:condition_a ],
        [ sh:datatype xsd:integer ;
            sh:description "List of 1-based condition set indices where condition A appears" ;
            sh:minInclusive 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path gene_review:condition_a_in_sets ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of proteins matching condition A in specified database" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:count_a ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of proteins matching condition B in specified database" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:count_b ],
        [ sh:datatype xsd:float ;
            sh:description "Proportion of B contained in A: |A ∩ B| / |B|. 1.0 means B is completely contained in A (B ⊆ A)." ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minCount 1 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path gene_review:containment_b_in_a ] ;
    sh:targetClass gene_review:PairwiseOverlap .

gene_review:ParsimonyAssessment a sh:NodeShape ;
    sh:closed true ;
    sh:description "Assessment of rule parsimony (simplicity vs complexity)" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Notes on parsimony - e.g., which conditions are redundant" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:notes ],
        [ sh:description "Parsimony assessment value" ;
            sh:in ( "PARSIMONIOUS" "ACCEPTABLE" "REDUNDANT" "OVERLY_COMPLEX" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:assessment ],
        [ sh:class gene_review:SupportingTextInReference ;
            sh:description "Supporting text from literature for this assessment" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:supported_by ] ;
    sh:targetClass gene_review:ParsimonyAssessment .

gene_review:PredictedAnnotation a sh:NodeShape ;
    sh:closed true ;
    sh:description "A single computational prediction and its review. Each prediction comes from a specific method and predicts a term (EC number, GO term, etc.) for the gene." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:Term ;
            sh:description "The predicted term (GO term, EC number, etc.)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gene_review:predicted_term ],
        [ sh:datatype xsd:string ;
            sh:description "Reference for the prediction method or study (e.g., PMID:37820725 for the Kim et al. 2023 DeepECTF study)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:source_reference_id ],
        [ sh:description "Type of predicted term (EC, GO_MF, GO_BP, GO_CC)" ;
            sh:in ( "EC" "GO_MF" "GO_BP" "GO_CC" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path gene_review:predicted_term_type ],
        [ sh:class gene_review:PredictionAssessment ;
            sh:description "Assessment of this prediction" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:review ],
        [ sh:datatype xsd:string ;
            sh:description "Version or date of the prediction method" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:source_version ],
        [ sh:datatype xsd:string ;
            sh:description "Name of the prediction method (e.g., DeepECTF, PANTHER_IBA, InterPro2GO, CLEAN, GloEC, MAPred, ProteinInfer)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:source_method ] ;
    sh:targetClass gene_review:PredictedAnnotation .

gene_review:PredictionAssessment a sh:NodeShape ;
    sh:closed true ;
    sh:description "Assessment of a single computational prediction. Uses categories from de Crécy-Lagard et al. 2025 (PMID:40703034) plus extensions for GO predictions." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Summary of the assessment rationale" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:summary ],
        [ sh:description "Type of error that led to the incorrect prediction, following Table 1 of de Crécy-Lagard et al. 2025" ;
            sh:in ( "FAILURE_TO_CAPTURE_LITERATURE" "NAMING_INCONSISTENCY" "MULTIPLE_FUNCTIONS" "CURATION_MISTAKE" "EXPERIMENTAL_MISTAKE" "PARALOG_OVERANNOTATION" "FREQUENCY_BIAS" "TRAINING_DATA_CONTAMINATION" "PATHWAY_CONTEXT_IGNORED" "IN_VITRO_NOT_IN_VIVO" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path gene_review:error_type ],
        [ sh:class gene_review:SupportingTextInReference ;
            sh:description "Supporting evidence for the assessment" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:supported_by ],
        [ sh:description "Assessment category for this prediction" ;
            sh:in ( "COR" "CNN" "LSP" "UNC" "PLI" "NPI" "REP" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:assessment ],
        [ sh:datatype xsd:integer ;
            sh:description "Confidence score following de Crécy-Lagard et al. 2025: 2 = concordant with evidence, 1 = uncertain, 0 = discordant with evidence" ;
            sh:maxCount 1 ;
            sh:maxInclusive 2 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:confidence_score ] ;
    sh:targetClass gene_review:PredictionAssessment .

gene_review:ProteinComplexDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a protein-containing complex or subcomplex." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:preferred_term ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:ComplexUnit ;
            sh:description "Active units or role-bearing components of the complex. This is used to avoid leaving functionally important complex structure as prose." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path gene_review:active_units ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:evidence ] ;
    sh:targetClass gene_review:ProteinComplexDescriptor .

gene_review:Question a sh:NodeShape ;
    sh:closed true ;
    sh:description "A question to be answered about the gene" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Experts to answer the question. These should be drawn from the authors of relevant publications already referenced. If no suitable experts are available, it's OK to leave this as an empty list!" ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:experts ],
        [ sh:datatype xsd:string ;
            sh:description "Question to be answered" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:question ] ;
    sh:targetClass gene_review:Question .

gene_review:RedundantAnnotation a sh:NodeShape ;
    sh:closed true ;
    sh:description "A GO annotation that is redundant with an existing InterPro2GO mapping" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "InterPro domain label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:interpro_label ],
        [ sh:datatype xsd:string ;
            sh:description "GO term label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:go_label ],
        [ sh:datatype xsd:string ;
            sh:description "GO term ID (e.g., GO:0004791)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:go_id ],
        [ sh:datatype xsd:string ;
            sh:description "InterPro ID that already maps to this GO term in ipr2go" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:interpro_source ] ;
    sh:targetClass gene_review:RedundantAnnotation .

gene_review:ReferenceReview a sh:NodeShape ;
    sh:closed true ;
    sh:description "Manual reviewer assessment of a reference - how relevant it is to the gene's function, and whether it is correctly cited and scientifically sound. Distinct from the machine-fetched id/title fields; all fields are optional and reviewer-supplied." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text note explaining the relevance/correctness judgment (e.g. what was verified, or why a citation is wrong, disputed, or low quality)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:review_notes ],
        [ sh:description "Reviewer judgment of how relevant the reference is to the gene's function and this review." ;
            sh:in ( "HIGH" "MEDIUM" "LOW" "NONE" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path gene_review:relevance ],
        [ sh:description "Reviewer's overall assessment of a reference's trustworthiness - both citation correctness (the identifier resolves to the intended paper that supports its use) and scientific soundness of that paper's claim." ;
            sh:in ( "VERIFIED" "UNVERIFIED" "WRONG_IDENTIFIER" "MISCITED" "DISPUTED" "LOW_QUALITY" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path gene_review:correctness ] ;
    sh:targetClass gene_review:ReferenceReview .

gene_review:RelatedEntry a sh:NodeShape ;
    sh:closed true ;
    sh:description "A relationship from this entry to another entry in the rule. Categorized as PREDICTS (this → other), PREDICTED_BY (other → this), or EQUIV (bidirectional)." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:description "Containment score (0-1) for the directional relationship. For PREDICTS: this_in_target (how much of this is contained in target). For PREDICTED_BY: target_in_this (how much of target is contained in this). For EQUIV: max of both directions." ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:containment ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of proteins in both this and target" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:intersection_count ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the related entry" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:target_id ],
        [ sh:datatype xsd:float ;
            sh:description "Jaccard similarity coefficient (0-1)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:jaccard_similarity ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of proteins exclusive to the \"source\" of the relationship. For PREDICTS: proteins in this but not target. For PREDICTED_BY: proteins in target but not this. For EQUIV: proteins in this but not target (A - B)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:exclusive_count ],
        [ sh:description "Type of relationship" ;
            sh:in ( "PREDICTS" "PREDICTED_BY" "EQUIV" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:relationship ] ;
    sh:targetClass gene_review:RelatedEntry .

gene_review:RelationDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a relation or connection predicate." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ] ;
    sh:targetClass gene_review:RelationDescriptor .

gene_review:Review a sh:NodeShape ;
    sh:closed true ;
    sh:description "A review of an existing annotation." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:Reference ;
            sh:description "IDs of the references" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gene_review:additional_reference_ids ],
        [ sh:class gene_review:KnowledgeGap ;
            sh:description "Curated, literature-grounded statements of what is NOT known — applicable at the level of the whole gene, a single existing annotation, a core function, a whole module, or a single module step/node. The inverse of core_functions: everywhere else the schema records what IS known; here it records, with the same evidentiary discipline, what is not. See the Function Knowledge Gaps project (projects/FUNCTION_KNOWLEDGE_GAPS.md)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gene_review:knowledge_gaps ],
        [ sh:description "Action to be taken" ;
            sh:in ( "ACCEPT" "KEEP_AS_NON_CORE" "REMOVE" "MODIFY" "MARK_AS_OVER_ANNOTATED" "UNDECIDED" "PENDING" "NEW" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path gene_review:action ],
        [ sh:datatype xsd:string ;
            sh:description "Summary of the review" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:summary ],
        [ sh:class gene_review:SupportingTextInReference ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:supported_by ],
        [ sh:datatype xsd:string ;
            sh:description "Reason for the action" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:reason ],
        [ sh:class gene_review:Term ;
            sh:description "If the action is MODIFY, then this is a list of proposed replacement terms" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gene_review:proposed_replacement_terms ] ;
    sh:targetClass gene_review:Review .

gene_review:RuleCondition a sh:NodeShape ;
    sh:closed true ;
    sh:description "A single condition in a rule antecedent" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "InterPro entry type (family, domain, active_site, etc.). Only populated for InterPro conditions (condition_type = INTERPRO). Extracted from InterPro metadata or API." ;
            sh:in ( "FAMILY" "DOMAIN" "ACTIVE_SITE" "BINDING_SITE" "CONSERVED_SITE" "REPEAT" "HOMOLOGOUS_SUPERFAMILY" "PTM" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path gene_review:interpro_type ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of proteins matching this condition in specified database. Only populated for domain/family conditions (InterPro, FunFam, PANTHER). Null for taxon and other condition types." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:protein_count ],
        [ sh:datatype xsd:string ;
            sh:description "Normalized CURIE form (e.g., InterPro:IPR000001, NCBITaxon:4751)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:curie ],
        [ sh:description "Type of condition" ;
            sh:in ( "INTERPRO" "FUNFAM" "PANTHER" "PFAM" "TAXON" "SEQUENCE_LENGTH" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:condition_type ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether this is a negative condition (NOT)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:negated ],
        [ sh:datatype xsd:string ;
            sh:description "The condition value (e.g., IPR000001, NCBITaxon:4751)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:value ],
        [ sh:datatype xsd:float ;
            sh:description "Measure of domain uniqueness (0.0 to 1.0). Calculated as 1.0 - mean(containment in other domains in same condition set). High score = more unique/specific domain. Low score = broad domain that commonly co-occurs." ;
            sh:maxCount 1 ;
            sh:maxInclusive 1e+00 ;
            sh:minInclusive 0e+00 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gene_review:uniqueness_score ],
        [ sh:description "Which protein database was queried (e.g., SWISSPROT, TREMBL). Defaults to SWISSPROT (reviewed proteins only). Important to specify since counts differ dramatically between databases." ;
            sh:in ( "SWISSPROT" "TREMBL" "UNIPROT" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path gene_review:protein_database ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:label ],
        [ sh:datatype xsd:string ;
            sh:description "Sample UniProt IDs matching this condition. Only included when protein_count < 20 to avoid bloating files. Limited to max 10 examples." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path gene_review:sample_proteins ] ;
    sh:targetClass gene_review:RuleCondition .

gene_review:RuleConditionSet a sh:NodeShape ;
    sh:closed true ;
    sh:description "A set of conditions that must ALL be true (conjunction/AND). Multiple condition sets in a rule are OR-ed together (disjunction)." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:RuleCondition ;
            sh:description "Conditions in this set (all must match)" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path gene_review:conditions ],
        [ sh:class gene_review:PairwiseOverlap ;
            sh:description "Pairwise overlap statistics for domain conditions in this set. Only computed for InterPro, FunFam, PANTHER conditions. Provides set difference metrics (uniqueness) and Jaccard similarity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:pairwise_overlap ],
        [ sh:datatype xsd:integer ;
            sh:description "1-based condition set number (CS1, CS2, CS3, etc.)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:number ],
        [ sh:datatype xsd:string ;
            sh:description "Reviewer notes on this specific condition set" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:notes ] ;
    sh:targetClass gene_review:RuleConditionSet .

gene_review:RuleGOAnnotation a sh:NodeShape ;
    sh:closed true ;
    sh:description "A GO annotation produced by the rule" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "GO term ID (e.g., GO:0004791)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:go_id ],
        [ sh:datatype xsd:string ;
            sh:description "GO term name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:go_label ],
        [ sh:datatype xsd:string ;
            sh:description "GO aspect (F, P, or C)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:aspect ] ;
    sh:targetClass gene_review:RuleGOAnnotation .

gene_review:RuleReviewEntry a sh:NodeShape ;
    sh:closed true ;
    sh:description "An entity in the rule - either a domain/family condition or a GO term target. Each entry tracks its relationships (predictions, predicted-by, equivalence) to other entries." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Identifier (IPR005982, GO:0004791, 3.50.50.60:FF:000064, etc.)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ],
        [ sh:description "Type of entry (INTERPRO, FUNFAM, PANTHER, GO_TERM, etc.)" ;
            sh:in ( "INTERPRO" "FUNFAM" "PANTHER" "GO_TERM" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path gene_review:type ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of proteins matching this condition (from SwissProt)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:protein_count ],
        [ sh:datatype xsd:integer ;
            sh:description "Which condition sets (1-based) contain this entry (for domain conditions only)" ;
            sh:minInclusive 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:appears_in_condition_sets ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:label ],
        [ sh:class gene_review:RelatedEntry ;
            sh:description "Relationships to other entries in the rule" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path gene_review:related_entries ],
        [ sh:datatype xsd:string ;
            sh:description "GO terms that this entry maps to via external mappings (e.g., ipr2go). Only populated for external entries not in the rule's condition sets." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:asserted_predicted_go_terms ],
        [ sh:datatype xsd:string ;
            sh:description "Source of this entry if external to the rule (e.g., 'ipr2go' for InterPro entries that map to the same GO term via InterPro2GO but are not part of any condition set)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:source ] ;
    sh:targetClass gene_review:RuleReviewEntry .

gene_review:TaxonomicScopeAssessment a sh:NodeShape ;
    sh:closed true ;
    sh:description "Assessment of taxonomic restriction appropriateness" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:SupportingTextInReference ;
            sh:description "Supporting text from literature for this assessment" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:supported_by ],
        [ sh:datatype xsd:string ;
            sh:description "Notes on taxonomic scope - suggested changes to taxon constraints" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:notes ],
        [ sh:description "Taxonomic scope assessment value" ;
            sh:in ( "TOO_BROAD" "APPROPRIATE" "TOO_NARROW" "MISSING" "UNNECESSARY" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:assessment ] ;
    sh:targetClass gene_review:TaxonomicScopeAssessment .

gene_review:TermMapping a sh:NodeShape ;
    sh:closed true ;
    sh:description "A mapping between the proposed term and an equivalent term in another ontology" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:Term ;
            sh:description "The target term in another ontology" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path gene_review:target_term ],
        [ sh:datatype xsd:string ;
            sh:description "Mapping predicate (e.g., 'skos:exactMatch', 'skos:closeMatch', 'skos:broadMatch', 'skos:narrowMatch')" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:predicate ] ;
    sh:targetClass gene_review:TermMapping .

gene_review:DomainDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a protein domain, motif, site, or architectural feature." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ] ;
    sh:targetClass gene_review:DomainDescriptor .

gene_review:GeneProductDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a gene product, protein, isoform, or gene-product form." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ] ;
    sh:targetClass gene_review:GeneProductDescriptor .

gene_review:ModuleContext a sh:NodeShape ;
    sh:closed true ;
    sh:description "Context that applies to a module node, variant, annoton, or connection." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:AnatomicalEntityDescriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:anatomical_locations ],
        [ sh:class gene_review:TaxonDescriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path gene_review:taxa ],
        [ sh:class gene_review:DevelopmentalStageDescriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:developmental_stages ],
        [ sh:class gene_review:CellularComponentDescriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:cellular_components ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gene_review:notes ],
        [ sh:class gene_review:Descriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:conditions ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:CellTypeDescriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path gene_review:cell_types ] ;
    sh:targetClass gene_review:ModuleContext .

gene_review:ParticipantSelector a sh:NodeShape ;
    sh:closed true ;
    sh:description "A selector for a concrete or abstract participant in a module annoton. This can ground to a gene, gene product, complex, family, domain, ortholog, homolog, or any entity satisfying a functional/domain constraint." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:DomainDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:domain ],
        [ sh:in ( "GENE" "GENE_PRODUCT" "PROTEIN_COMPLEX" "FAMILY" "DOMAIN" "ORTHOLOG_OF" "HOMOLOG_OF" "ANY_WITH_FUNCTION" "ANY_WITH_DOMAIN" "ANY_PARTICIPANT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path gene_review:selector_type ],
        [ sh:class gene_review:GeneDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gene_review:homolog_of ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:GeneDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path gene_review:ortholog_of ],
        [ sh:class gene_review:TaxonDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path gene_review:taxon ],
        [ sh:class gene_review:GeneProductDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:gene_product ],
        [ sh:class gene_review:FamilyDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:family ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path gene_review:notes ],
        [ sh:class gene_review:GeneDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path gene_review:gene ],
        [ sh:class gene_review:MolecularFunctionDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path gene_review:required_function ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:ProteinComplexDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:protein_complex ],
        [ sh:class gene_review:DomainDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path gene_review:required_domain ] ;
    sh:targetClass gene_review:ParticipantSelector .

gene_review:ProposedOntologyTerm a sh:NodeShape ;
    sh:closed true ;
    sh:description "A proposed new ontology term that should exist but doesn't currently" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Proposed definition for the new term" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:proposed_definition ],
        [ sh:class gene_review:SupportingTextInReference ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:supported_by ],
        [ sh:datatype xsd:string ;
            sh:description "Proposed name for the new term" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:proposed_name ],
        [ sh:class gene_review:TermMapping ;
            sh:description "Proposed mappings to equivalent terms in other ontologies" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:proposed_mappings ],
        [ sh:datatype xsd:string ;
            sh:description "Justification for why this term is needed" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:justification ],
        [ sh:class gene_review:Term ;
            sh:description "Proposed parent term in the ontology hierarchy" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gene_review:proposed_parent ] ;
    sh:targetClass gene_review:ProposedOntologyTerm .

gene_review:TaxonDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a taxon or taxonomic scope." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ] ;
    sh:targetClass gene_review:TaxonDescriptor .

gene_review:GeneDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a gene or locus." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ] ;
    sh:targetClass gene_review:GeneDescriptor .

gene_review:ModuleNode a sh:NodeShape ;
    sh:closed true ;
    sh:description "A node in a module. Nodes can be recursively decomposed using parts and variant_sets, and may also carry leaf annotons and connections." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:ModuleConnection ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path gene_review:connections ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path gene_review:evidence ],
        [ sh:class gene_review:KnowledgeGap ;
            sh:description "Curated, literature-grounded statements of what is NOT known — applicable at the level of the whole gene, a single existing annotation, a core function, a whole module, or a single module step/node. The inverse of core_functions: everywhere else the schema records what IS known; here it records, with the same evidentiary discipline, what is not. See the Function Knowledge Gaps project (projects/FUNCTION_KNOWLEDGE_GAPS.md)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path gene_review:knowledge_gaps ],
        [ sh:class gene_review:Descriptor ;
            sh:description "Optional ontology/database grounding for this module node." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:concepts ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:id ],
        [ sh:class gene_review:ModuleVariantSet ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path gene_review:variant_sets ],
        [ sh:in ( "MODULE" "BIOLOGICAL_PROCESS" "MOLECULAR_FUNCTION" "METABOLIC_PATHWAY" "SIGNALING_PATHWAY" "DEVELOPMENTAL_PROCESS" "CELLULAR_COMPONENT" "ORGANELLE_LIFECYCLE" "PROTEIN_COMPLEX" "REACTION" "TRANSPORT_STEP" "REGULATORY_STEP" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path gene_review:module_type ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:ModulePart ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path gene_review:parts ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:label ],
        [ sh:class gene_review:ModuleAnnoton ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path gene_review:annotons ],
        [ sh:class gene_review:ModuleContext ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gene_review:context ] ;
    sh:targetClass gene_review:ModuleNode .

gene_review:MolecularFunctionDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a molecular function. Extra slots capture common functional nuance without requiring formal post-composition." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:Descriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:cofactors ],
        [ sh:class gene_review:Descriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:targets ],
        [ sh:class gene_review:Descriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gene_review:cargo ],
        [ sh:class gene_review:Descriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path gene_review:products ],
        [ sh:class gene_review:Descriptor ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path gene_review:substrates ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gene_review:description ],
        [ sh:class gene_review:CellularComponentDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gene_review:source_location ],
        [ sh:class gene_review:CellularComponentDescriptor ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gene_review:destination_location ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gene_review:preferred_term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path gene_review:notes ] ;
    sh:targetClass gene_review:MolecularFunctionDescriptor .

gene_review:CellularComponentDescriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A descriptor for a cellular component, organelle, compartment, or complex location." ;
    sh:ignoredProperties ( gene_review:active_units rdf:type ) ;
    sh:property [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ] ;
    sh:targetClass gene_review:CellularComponentDescriptor .

gene_review:KnowledgeGap a sh:NodeShape ;
    sh:closed true ;
    sh:description "A curated, literature-grounded statement of what is NOT known about a gene product, core function, module, or step — its molecular activity, mechanism, partner(s), localization, or biological role. A knowledge gap is a reviewer judgment reached by reading the primary literature, NOT a pattern in the annotations: a heavily annotated gene can hide a gaping mechanistic hole, and a sparsely annotated one can be perfectly understood and merely under-curated. Each gap is a small, defensible scholarly object with the same evidentiary discipline used for positive claims. See projects/FUNCTION_KNOWLEDGE_GAPS.md for the methodology and worked exemplars." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Why closing this gap matters." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:significance ],
        [ sh:class gene_review:ProposedOntologyTerm ;
            sh:description "For ONTOLOGY gaps, the new ontology term(s) that would let the knowledge be expressed (e.g. \"structural constituent of complex X\"). May elaborate the gene's top-level proposed_new_terms." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path gene_review:proposed_terms ],
        [ sh:description "The kind(s) of ignorance — biology, curation, and/or ontology — which determines who can resolve it. Multiple values denote a blend (e.g. a biology gap with an ontology shadow)." ;
            sh:in ( "BIOLOGY" "CURATION" "ONTOLOGY" ) ;
            sh:order 2 ;
            sh:path gene_review:gap_kind ],
        [ sh:datatype xsd:string ;
            sh:description "What would resolve the gap — the experiment, ontology term, or curation action. For ONTOLOGY gaps, pair with proposed_terms (or the gene's top-level proposed_new_terms)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gene_review:resolution ],
        [ sh:description "Lifecycle status of the gap, tracking progress toward resolution." ;
            sh:in ( "OPEN" "NARROWING" "CLOSING" "RESOLVED" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path gene_review:status ],
        [ sh:datatype xsd:string ;
            sh:description "The specific unknown, stated precisely. Not \"role unclear\" but e.g. \"the direct substrate / the catalytic activity / the essential partner is undetermined\"." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:gap_statement ],
        [ sh:class gene_review:SupportingTextInReference ;
            sh:description "Evidence that the unknown is REAL and not merely uncurated — ideally the field's own admissions of ignorance (\"remains to be determined\", \"the precise role is unknown\"). The supporting_text is a verbatim substring of the cited reference and is checked by the reference validator exactly like supported_by. When the only available source is a DOI-only paper or a local analysis, anchor provenance to that reference_id (e.g. a file: path)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path gene_review:provenance ],
        [ sh:description "Which GO aspect (or pattern) is dark for this gap. Most \"dark\" genes are not uniformly dark." ;
            sh:in ( "MF_DARK" "BP_DARK" "CC_DARK" "WHOLLY_DARK" "RESIDUAL_SUBGAP" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path gene_review:dark_aspect ],
        [ sh:datatype xsd:string ;
            sh:description "What IS firmly established, so the gap is sharply delimited. The edge of current knowledge against which the gap is defined." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:boundary ] ;
    sh:targetClass gene_review:KnowledgeGap .

gene_review:Reference a sh:NodeShape ;
    sh:closed true ;
    sh:description "A reference is a published text  that describes a finding or a method. References might be formal publications (where the ID is a PMID), or for methods, a GO_REF. Additionally, a reference to a local ad-hoc analysis or review can be made by using the `file:` prefix." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gene_review:Finding ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path gene_review:findings ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the full text is unavailable" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:full_text_unavailable ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ],
        [ sh:datatype xsd:string ;
            sh:description "Title of the entity" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:class gene_review:ReferenceReview ;
            sh:description "Manual reviewer assessment of this reference (relevance, and citation correctness / scientific soundness). Reviewer-supplied, distinct from the machine-fetched id/title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gene_review:reference_review ],
        [ sh:description "The kind of publication or source this reference is (e.g. primary research article, review, meta-analysis, database record, AI deep-research report). For PMIDs this is normally inferred from the PubMed publication-type ('PT') metadata rather than set by hand; for non-PMID references (GO_REF, Reactome, file:) it is inferred from the identifier. Lets analyses ask, e.g., whether review articles or abstracts alone are sufficient to support a given annotation action." ;
            sh:in ( "PRIMARY_RESEARCH" "REVIEW" "SYSTEMATIC_REVIEW" "META_ANALYSIS" "COMMENT_EDITORIAL" "CASE_REPORT" "PREPRINT" "DATABASE" "BIOINFORMATICS" "DEEP_RESEARCH" "OTHER" "UNKNOWN" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path gene_review:publication_type ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the reference is invalid (e.g., retracted or replaced)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:is_invalid ] ;
    sh:targetClass gene_review:Reference .

gene_review:SupportingTextInReference a sh:NodeShape ;
    sh:closed true ;
    sh:description "A supporting text in a reference." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether the full text is unavailable" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:full_text_unavailable ],
        [ sh:datatype xsd:string ;
            sh:description "Supporting text from the full-text PDF when the full text cannot be committed to the repository. This is an interim solution for cases where we have access to full text but cannot share it publicly. Unlike supporting_text, this field is not validated against cached publication text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:supporting_text_fulltext ],
        [ sh:datatype xsd:string ;
            sh:description "Supporting text from the publication. This should be exact substrings. Different substrings can be broken up by '...'s. These substrings will be checked against the actual text of the paper. If editorialization is necessary, put this in square brackets (this is not checked). For example, you can say '...[CFAP300 shows] transport within cilia is IFT dependent...'" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:supporting_text ],
        [ sh:class gene_review:Reference ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path gene_review:reference_id ],
        [ sh:description "Type of section in the reference (e.g., 'ABSTRACT', 'METHODS', 'RESULTS', 'DISCUSSION')" ;
            sh:in ( IAO:0000305 IAO:0000315 IAO:0000630 IAO:0000316 IAO:0000639 IAO:0000317 IAO:0000318 IAO:0000319 IAO:0000615 IAO:0000326 IAO:0000326 "DATABASE_ENTRY" "OTHER" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path gene_review:reference_section_type ] ;
    sh:targetClass gene_review:SupportingTextInReference .

gene_review:Descriptor a sh:NodeShape ;
    sh:closed true ;
    sh:description "A human-friendly descriptor with optional ontology/database grounding. The preferred_term may be more nuanced than the term label, and the term may be absent when no good identifier exists yet." ;
    sh:ignoredProperties ( gene_review:substrates gene_review:cargo gene_review:occurs_in gene_review:targets gene_review:active_units rdf:type gene_review:source_location gene_review:inputs gene_review:outputs gene_review:products gene_review:ends_with gene_review:cofactors gene_review:destination_location gene_review:representative_members gene_review:starts_with ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:notes ],
        [ sh:class gene_review:Term ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gene_review:term ],
        [ sh:class gene_review:EvidenceItem ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gene_review:evidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:description ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:preferred_term ] ;
    sh:targetClass gene_review:Descriptor .

gene_review:EvidenceItem a sh:NodeShape ;
    sh:closed true ;
    sh:description "A lightweight citable source for module-level assertions. The source may be a PMID, DOI, database record, local file, pathway record, issue, or any other citable artifact. This is deliberately less strict than the publication quote validation used in gene reviews." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gene_review:notes ],
        [ sh:datatype xsd:string ;
            sh:description "Optional quote or excerpt from the evidence source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:supporting_text ],
        [ sh:datatype xsd:string ;
            sh:description "The assertion this evidence supports in this module." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gene_review:statement ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gene_review:url ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier for the evidence source, e.g. PMID:123456, DOI:..., Reactome:R-HSA-..., MetaCyc:..., file:..." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:source_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gene_review:title ] ;
    sh:targetClass gene_review:EvidenceItem .

gene_review:Term a sh:NodeShape ;
    sh:closed true ;
    sh:description "A term in a specific ontology" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Ontology of the term. E.g `go`, `cl`, `hp`" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gene_review:ontology ],
        [ sh:datatype xsd:string ;
            sh:description "the term name" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description "A CURIE for a term or database object in GO, CL, CHEBI, UniProtKB, PANTHER, etc." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gene_review:id ] ;
    sh:targetClass gene_review:Term .

