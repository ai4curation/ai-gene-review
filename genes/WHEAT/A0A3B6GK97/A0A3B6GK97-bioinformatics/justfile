# Reproducible patatin/pPLA subfamily + catalytic-site analysis for A0A3B6GK97
# Usage: just all

# Fetch query + reference sequences from UniProt (live)
fetch:
    uv run python scripts/fetch_sequences.py --accessions data/reference_accessions.tsv --out data/sequences.fasta

# Run MSA, subfamily placement, motif scan, catalytic-site analysis
analyze:
    uv run python scripts/analyze.py --fasta data/sequences.fasta --outdir results

# Control: confirm pipeline is input-driven (active patatin as query -> motifs present)
test-control:
    uv run python scripts/make_control.py
    uv run python scripts/analyze.py --fasta data/test_control.fasta --outdir results_control

# Full pipeline
all: fetch analyze test-control

clean:
    rm -rf results results_control data/sequences.fasta data/test_control.fasta
