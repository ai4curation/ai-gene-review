# GAT2 GATA zinc-finger / paralog bioinformatics
# Requires: uv, mafft on PATH

# Run the full analysis
all: zinc-finger dbd-identity

# Detect GATA Cys4 zinc fingers in all yeast GATA factors (+ negative control)
zinc-finger:
    uv run python scripts/find_gata_zinc_finger.py data/yeast_gata_factors.fasta --json results/zinc_finger_motifs.json
    uv run python scripts/find_gata_zinc_finger.py data/negative_control_ACT1.fasta

# Pairwise DBD identity matrix across yeast GATA factors
dbd-identity:
    uv run python scripts/pairwise_dbd_identity.py data/yeast_gata_factors.fasta --outdir results --flank 8
