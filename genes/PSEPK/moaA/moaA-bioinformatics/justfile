repo_root := "../../../.."

all: moaA mob-like

moaA:
    uv run python analyze_sequences.py \
      --manifest moaA_targets.tsv \
      --repo-root {{repo_root}} \
      --motif radical_sam='C...C..C' \
      --motif cys_pair='C..C' \
      --features-output moaA_features.tsv \
      --pairwise-output moaA_pairwise_identity.tsv \
      --kegg-output moaA_kegg_orthology.tsv

mob-like:
    uv run python analyze_sequences.py \
      --manifest mob_like_targets.tsv \
      --repo-root {{repo_root}} \
      --features-output mob_like_features.tsv \
      --pairwise-output mob_like_pairwise_identity.tsv \
      --kegg-output mob_like_kegg_orthology.tsv
