{
  "labels": {
    "app": "bioreason-smoke",
    "mode": "sft-no-go-graph"
  },
  "taskGroups": [
    {
      "taskCount": 1,
      "parallelism": 1,
      "taskSpec": {
        "runnables": [
          {
            "container": {
              "imageUri": "__IMAGE_URI__",
              "entrypoint": "/bin/bash",
              "commands": [
                "/app/run_smoketest.sh"
              ]
            }
          }
        ],
        "computeResource": {
          "cpuMilli": 8000,
          "memoryMib": 61440,
          "bootDiskMib": 204800
        },
        "maxRunDuration": "14400s",
        "maxRetryCount": 0,
        "environment": {
          "variables": {
            "BIOREASON_MODEL_ID": "wanglab/bioreason-pro-sft",
            "GOGPT_MODEL_ID": "wanglab/gogpt",
            "INPUT_GCS_URI": "__INPUT_GCS_URI__",
            "OUTPUT_GCS_PREFIX": "__OUTPUT_GCS_PREFIX__",
            "MAX_MODEL_LEN": "8192",
            "MAX_NEW_TOKENS": "1200",
            "TEMPERATURE": "0.0",
            "TOP_P": "0.95",
            "MODEL_CACHE_DIR": "/workdir/hf-cache"
          }
        }
      }
    }
  ],
  "allocationPolicy": {
    "serviceAccount": {
      "email": "__SERVICE_ACCOUNT__"
    },
    "instances": [
      {
        "installGpuDrivers": true,
        "policy": {
          "provisioningModel": "__PROVISIONING_MODEL__",
          "machineType": "__MACHINE_TYPE__",
          "reservation": "NO_RESERVATION"
        }
      }
    ],
    "location": {
      "allowedLocations": [
        "__ALLOWED_LOCATION__"
      ]
    }
  },
  "logsPolicy": {
    "destination": "CLOUD_LOGGING"
  }
}
