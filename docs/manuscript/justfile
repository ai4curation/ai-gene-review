# AUGR framework manuscript recipes

manuscript := "manuscript.tex"
pdf := "manuscript.pdf"

# Build the manuscript PDF from LaTeX source (requires latexmk + xelatex + bibtex)
pdf:
    latexmk -xelatex -interaction=nonstopmode -halt-on-error -file-line-error {{manuscript}}
    @echo "Built {{pdf}}"

# Word count for the manuscript
wc:
    @wc -w {{manuscript}}

# Clean LaTeX build outputs (keeps the .tex/.bib source)
clean:
    rm -f {{pdf}} manuscript.aux manuscript.bbl manuscript.blg \
        manuscript.fdb_latexmk manuscript.fls manuscript.log \
        manuscript.out manuscript.toc manuscript.xdv
