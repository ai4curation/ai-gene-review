      "mechanisms": [
        {
          "mechanism_id": 1,
          "is_detailed": true,
          "mechanism_text": "Asp 100 acts as a general base to remove a proton from the O6 hydroxyl group of glucose, which can then attack the gamma phosphorous of ATP. Simultaneously, Lys 169 acts as an acid catalyst, protonating the gamma phosphate's O3. There is then subsequent proton transfer from Asp205 to Lys169 so that the enzyme is ready for another round of catalysis.",
          "rating": 3,
          "components_summary": "proton transfer, overall product formed, proton relay, bimolecular nucleophilic substitution, overall reactant used, native state of enzyme regenerated",
          "steps": [
            {
              "step_id": 1,
              "description": "Asp205 deprotonates the 6' OH of glucose, increasing its nucleophilicity to then attack the gamma phosphate on ATP.  Lys 169 protonates the gamma phosphate concomitantly.",
              "figure": "www.ebi.ac.uk/thornton-srv/m-csa/media/schemes_svg/macie_entry_592_1_1",
              "is_product": false,
              "marvin_xml": "www.ebi.ac.uk/thornton-srv/m-csa/media/schemes/macie_entry_592_1_1.mrv"
            },
            {
              "step_id": 2,
              "description": "Proton transfer from Asp205 to Lys169 via the gamma phosphate non-bridging O.",
              "figure": "www.ebi.ac.uk/thornton-srv/m-csa/media/schemes_svg/macie_entry_592_1_2",
              "is_product": false,
              "marvin_xml": "www.ebi.ac.uk/thornton-srv/m-csa/media/schemes/macie_entry_592_1_2.mrv"
            },
