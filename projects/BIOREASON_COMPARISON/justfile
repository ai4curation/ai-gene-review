# BioReason Comparison project recipes

article_dir := "article"
manuscript := article_dir / "manuscript.md"
pdf := article_dir / "manuscript.pdf"
short_abstract := article_dir / "short-abstract.md"
short_pdf := article_dir / "short-abstract.pdf"

# Build the manuscript PDF via pandoc + pdflatex
pdf:
    cd {{justfile_directory()}} && pandoc {{manuscript}} \
        -o {{pdf}} \
        --pdf-engine=xelatex \
        -V geometry:margin=1in \
        -V fontsize=11pt \
        -V linkcolor=blue \
        -V urlcolor=blue \
        -V mainfont="Times New Roman" \
        --number-sections \
        -V header-includes='\usepackage{longtable,booktabs,array}' \
        -V header-includes='\usepackage{float}\floatplacement{table}{H}' \
        --from markdown+yaml_metadata_block
    @echo "Built {{pdf}}"

# Build the short abstract PDF
short-abstract-pdf:
    cd {{justfile_directory()}} && pandoc {{short_abstract}} \
        -o {{short_pdf}} \
        --pdf-engine=xelatex \
        -V geometry:margin=1in \
        -V fontsize=11pt \
        -V mainfont="Times New Roman" \
        --from markdown
    @echo "Built {{short_pdf}}"

# Build all PDFs
all: pdf short-abstract-pdf

# Word count for the manuscript
wc:
    @wc -w {{manuscript}}

# Open the manuscript PDF
open: pdf
    open {{pdf}}

# Clean generated PDFs
clean:
    rm -f {{pdf}} {{short_pdf}}
