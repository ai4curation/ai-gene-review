# BioReason Comparison project recipes

article_dir := "article"
manuscript := article_dir / "manuscript.md"
pdf := article_dir / "manuscript.pdf"
short_abstract := article_dir / "short-abstract.md"
short_pdf := article_dir / "short-abstract.pdf"
notebooks_dir := "notebooks"
slides := article_dir / "slides.md"
slides_html := article_dir / "slides.html"

# Build the manuscript PDF via pandoc + pdflatex
pdf:
    cd {{justfile_directory()}} && pandoc {{manuscript}} \
        -o {{pdf}} \
        --pdf-engine=xelatex \
        -V geometry:margin=1in \
        -V fontsize=11pt \
        -V linkcolor=blue \
        -V urlcolor=blue \
        -V mainfont="Times New Roman" \
        --number-sections \
        -V header-includes='\usepackage{longtable,booktabs,array}' \
        -V header-includes='\usepackage{float}\floatplacement{table}{H}' \
        --resource-path={{article_dir}} \
        --from markdown+yaml_metadata_block
    @echo "Built {{pdf}}"

# Build the short abstract PDF
short-abstract-pdf:
    cd {{justfile_directory()}} && pandoc {{short_abstract}} \
        -o {{short_pdf}} \
        --pdf-engine=xelatex \
        -V geometry:margin=1in \
        -V fontsize=11pt \
        -V mainfont="Times New Roman" \
        --from markdown
    @echo "Built {{short_pdf}}"

# Build all PDFs
all: pdf short-abstract-pdf

# Recompute the summary-statistics notebooks from the committed gene files.
# Regenerates the .ipynb from build_notebooks.py and executes them in place, so
# every table/figure is derived live (Table 1 distribution, Table 2 per-organism
# means in 01; the de Crecy-Lagard assessment distribution / Table 5 analog in 02).
# Re-running after the manual term-level review lands reproduces Table 5 verbatim.
stats:
    cd {{justfile_directory()}}/{{notebooks_dir}} && \
        uv run python build_notebooks.py && \
        uv run jupyter nbconvert --to notebook --execute --inplace *.ipynb
    @echo "Executed stats notebooks in {{notebooks_dir}}/ (outputs embedded)"

# Export the executed stats notebooks to standalone HTML for browsing.
stats-html: stats
    cd {{justfile_directory()}}/{{notebooks_dir}} && \
        uv run jupyter nbconvert --to html *.ipynb
    @echo "Wrote {{notebooks_dir}}/*.html"

# Render the Function-COSI slide deck (Marp markdown -> self-contained HTML).
# Needs a browser for --pdf/--pptx; HTML works headless.
slides:
    cd {{justfile_directory()}}/{{article_dir}} && \
        npx --yes @marp-team/marp-cli@latest slides.md --html --allow-local-files -o slides.html
    @echo "Built {{slides_html}}"

# Word count for the manuscript
wc:
    @wc -w {{manuscript}}

# Open the manuscript PDF
open: pdf
    open {{pdf}}

# Clean generated PDFs and notebook HTML exports
clean:
    rm -f {{pdf}} {{short_pdf}}
    rm -f {{notebooks_dir}}/*.html {{notebooks_dir}}/figures/*.repro.png
