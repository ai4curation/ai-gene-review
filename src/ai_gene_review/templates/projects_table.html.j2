<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Projects - AI Gene Review</title>
    <style>
        :root {
            --color-primary: #3498db;
            --bg-light: #f9fafb;
            --border-color: #e5e7eb;
            --text-muted: #6b7280;
            --text-primary: #111827;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            line-height: 1.6;
            color: var(--text-primary);
            background-color: #ffffff;
            padding: 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .breadcrumb { margin-bottom: 1.5rem; font-size: 0.875rem; color: var(--text-muted); }
        .breadcrumb a { color: var(--color-primary); text-decoration: none; }
        .breadcrumb a:hover { text-decoration: underline; }
        .header { border-bottom: 2px solid var(--border-color); padding-bottom: 1.5rem; margin-bottom: 2rem; }
        h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; color: #1f2937; }
        .subtitle { color: var(--text-muted); font-size: 1.05rem; }
        .meta-note { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1.5rem; }
        table { border-collapse: collapse; width: 100%; font-size: 0.95rem; }
        thead th {
            text-align: left;
            border-bottom: 2px solid var(--border-color);
            padding: 0.6rem 0.75rem;
            position: sticky;
            top: 0;
            background: #ffffff;
        }
        tbody td { padding: 0.55rem 0.75rem; border-bottom: 1px solid var(--border-color); vertical-align: top; }
        tbody tr:nth-child(even) { background: var(--bg-light); }
        td a { color: var(--color-primary); text-decoration: none; }
        td a:hover { text-decoration: underline; }
        .muted { color: var(--text-muted); }
        code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85em; }
    </style>
</head>
<body>
    <nav class="breadcrumb">
        <a href="../index.html">Home</a> / <a href="index.html">Projects</a> / All Projects
    </nav>

    <div class="header">
        <h1>All Projects</h1>
        <p class="subtitle">Complete, automatically generated index of every project page in <code>projects/</code></p>
    </div>

    <p class="meta-note">{{ rows | length }} projects. This table is derived from each project's
    YAML frontmatter; the <a href="index.html">curated index</a> is the hand-organized entry point.</p>

    <table>
        <thead>
            <tr>
                <th>Project</th>
                <th>Species</th>
                <th>Status</th>
                <th>Supporting docs</th>
            </tr>
        </thead>
        <tbody>
        {% for row in rows %}
            <tr>
                <td><a href="{{ row.url }}">{{ row.title }}</a><br><code class="muted">{{ row.slug }}</code></td>
                <td>{% if row.species %}{{ row.species }}{% else %}<span class="muted">&mdash;</span>{% endif %}</td>
                <td>{% if row.status %}{{ row.status }}{% else %}<span class="muted">&mdash;</span>{% endif %}</td>
                <td>{% if row.support_count %}{{ row.support_count }} file{{ 's' if row.support_count != 1 else '' }}{% else %}<span class="muted">&mdash;</span>{% endif %}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</body>
</html>
