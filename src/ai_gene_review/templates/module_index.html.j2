<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - AI Gene Review</title>
    <style>
        :root {
            --bg-page: #f7f8fb;
            --bg-panel: #ffffff;
            --bg-soft: #f2f6f8;
            --border: #d9e1e7;
            --text: #17212b;
            --muted: #637282;
            --accent: #0f766e;
            --accent-soft: #dff4f0;
            --blue: #2563eb;
            --amber: #b45309;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            color: var(--text);
            background: var(--bg-page);
            line-height: 1.55;
        }

        a {
            color: var(--blue);
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .page {
            max-width: 1180px;
            margin: 0 auto;
            padding: 24px;
        }

        .header {
            background: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 22px 24px;
            margin-bottom: 18px;
        }

        h1 {
            margin: 0 0 8px;
            font-size: 2rem;
        }

        .muted {
            color: var(--muted);
        }

        .toolbar {
            display: grid;
            grid-template-columns: minmax(180px, 1fr) auto;
            gap: 10px;
            margin: 18px 0;
        }

        .search {
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 9px 10px;
            font: inherit;
        }

        .count {
            align-self: center;
            color: var(--muted);
            font-weight: 600;
        }

        .module-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 14px;
        }

        .module-card {
            background: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 16px;
        }

        .module-card.is-hidden {
            display: none;
        }

        .module-title {
            display: inline-block;
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .description {
            color: #31404e;
            margin: 0 0 12px;
        }

        .pill-row {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin: 8px 0;
        }

        .pill {
            display: inline-flex;
            align-items: center;
            padding: 4px 8px;
            border: 1px solid var(--border);
            border-radius: 999px;
            background: var(--bg-soft);
            color: #304150;
            font-size: 0.8rem;
            font-weight: 650;
            white-space: nowrap;
        }

        .pill.type {
            background: var(--accent-soft);
            border-color: #b8dfd8;
            color: var(--accent);
        }

        .pill.status {
            background: #fff7ed;
            border-color: #fed7aa;
            color: var(--amber);
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
            margin-top: 12px;
        }

        .stat {
            background: #fbfcfd;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 7px 8px;
        }

        .stat strong {
            display: block;
        }

        .stat span {
            color: var(--muted);
            font-size: 0.76rem;
            text-transform: uppercase;
        }

        @media (max-width: 720px) {
            .page {
                padding: 14px;
            }

            .toolbar {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
<main class="page">
    <header class="header">
        <h1>{{ title }}</h1>
        <p class="muted">Reusable biological module sketches rendered from YAML.</p>
    </header>

    <section class="toolbar">
        <input class="search" type="search" placeholder="Filter modules" data-module-search>
        <div class="count"><span data-visible-count>{{ total_modules }}</span> / {{ total_modules }} modules</div>
    </section>

    <section class="module-grid">
        {%- for module in modules %}
            <article class="module-card" data-module-card>
                <a class="module-title" href="{{ module.href }}">{{ module.title }}</a>
                {%- if module.description %}
                    <p class="description">{{ module.description }}</p>
                {%- endif %}
                <div class="pill-row">
                    {%- if module.id %}<span class="pill">{{ module.id }}</span>{% endif -%}
                    {%- if module.status %}<span class="pill status">{{ module.status }}</span>{% endif -%}
                    {%- if module.module_type %}<span class="pill type">{{ module.module_type | enum_label }}</span>{% endif -%}
                </div>
                {%- if module.concepts %}
                    <div class="pill-row">
                        {%- for concept in module.concepts %}
                            <span class="pill">{{ concept }}</span>
                        {%- endfor %}
                    </div>
                {%- endif %}
                <div class="stats">
                    <div class="stat"><strong>{{ module.stats.nodes }}</strong><span>Nodes</span></div>
                    <div class="stat"><strong>{{ module.stats.annotons }}</strong><span>Annotons</span></div>
                    <div class="stat"><strong>{{ module.stats.variant_sets }}</strong><span>Variant Sets</span></div>
                </div>
                <p class="muted">{{ module.source_path }}</p>
            </article>
        {%- endfor %}
    </section>
</main>

<script>
    const input = document.querySelector("[data-module-search]");
    const count = document.querySelector("[data-visible-count]");
    const cards = Array.from(document.querySelectorAll("[data-module-card]"));
    if (input) {
        input.addEventListener("input", () => {
            const query = input.value.trim().toLowerCase();
            let visible = 0;
            cards.forEach((card) => {
                const matches = !query || card.textContent.toLowerCase().includes(query);
                card.classList.toggle("is-hidden", !matches);
                if (matches) {
                    visible += 1;
                }
            });
            if (count) {
                count.textContent = String(visible);
            }
        });
    }
</script>
</body>
</html>
